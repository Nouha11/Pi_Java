<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gamification.RewardFormController"
            stylesheets="@/css/gamification.css"
            prefWidth="560" prefHeight="780"
            style="-fx-background-color: #f0f2f8;">

    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" spacing="0">

        <HBox styleClass="form-header" alignment="CENTER_LEFT" style="-fx-padding: 20 24;">
            <Label text="Reward Form" styleClass="form-title"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="16" style="-fx-padding: 20 24;">

                <VBox styleClass="section-card" spacing="12" style="-fx-padding: 20;">
                    <Label text="Reward Details"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b4fd8;"/>

                    <!-- Name -->
                    <VBox spacing="3">
                        <Label text="* Name" styleClass="field-label"/>
                        <TextField fx:id="nameField" promptText="Min. 3 characters, must be unique"/>
                        <Label fx:id="errName" text="" styleClass="field-error"
                               managed="false" visible="false"/>
                    </VBox>

                    <!-- Description -->
                    <VBox spacing="3">
                        <Label text="Description" styleClass="field-label"/>
                        <TextArea fx:id="descriptionArea" prefRowCount="3" wrapText="true"/>
                    </VBox>

                    <!-- Type / Value / Required Level -->
                    <HBox spacing="14">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="* Type" styleClass="field-label"/>
                            <ComboBox fx:id="typeCombo" maxWidth="Infinity"/>
                            <Label fx:id="errType" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="* Value (pts)" styleClass="field-label"/>
                            <TextField fx:id="valueField" promptText="e.g. 100"/>
                            <Label fx:id="errValue" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Required Level" styleClass="field-label"/>
                            <TextField fx:id="requiredLevelField" promptText="Leave blank if none"/>
                            <Label fx:id="errRequiredLevel" text="" styleClass="field-error"
                                   managed="false" visible="false"/>
                        </VBox>
                    </HBox>

                    <!-- Requirement -->
                    <VBox spacing="3">
                        <Label text="Requirement" styleClass="field-label"/>
                        <TextField fx:id="requirementField" promptText="e.g. Complete 10 posts"/>
                    </VBox>

                    <CheckBox fx:id="isActiveCheck" text="Reward is active" selected="true"
                              style="-fx-font-size: 13px; -fx-text-fill: #2d3748;"/>
                </VBox>

                <!-- Icon picker -->
                <VBox styleClass="section-card" spacing="12" style="-fx-padding: 20;">
                    <Label text="Icon"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b4fd8;"/>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: #f0f2f8; -fx-border-color: #dde2f5;
                                          -fx-border-radius: 10; -fx-background-radius: 10;"
                                   minWidth="96" minHeight="96" maxWidth="96" maxHeight="96">
                            <ImageView fx:id="iconPreview" fitWidth="88" fitHeight="88"
                                       preserveRatio="true" smooth="true"/>
                        </StackPane>
                        <VBox spacing="8">
                            <Button fx:id="pickIconBtn" text="Choose Image"
                                    onAction="#handlePickIcon" styleClass="btn-secondary"/>
                            <Label fx:id="iconPathLabel" text="No image selected"
                                   wrapText="true" maxWidth="220"
                                   style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Link Games -->
                <VBox styleClass="section-card" spacing="10" style="-fx-padding: 20;">
                    <Label text="Link Games"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3b4fd8;"/>
                    <Label text="Hold Ctrl to select multiple games"
                           style="-fx-text-fill: #a0aec0; -fx-font-size: 11px;"/>
                    <ListView fx:id="gamesList" prefHeight="130"/>
                </VBox>

            </VBox>
        </ScrollPane>

        <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="form-footer" style="-fx-padding: 14 24;">
            <Button text="Cancel" onAction="#handleCancel" styleClass="btn-ghost"/>
            <Button fx:id="saveBtn" text="Save Reward" onAction="#handleSave" styleClass="btn-primary"/>
        </HBox>
    </VBox>
</AnchorPane>
