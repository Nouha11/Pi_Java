<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gamification.GameRewardController"
            stylesheets="@/css/gamification.css"
            style="-fx-background-color: #f0f2f8;">
    <top>
        <VBox styleClass="toolbar">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 16 20 8 20;">
                <Label text="🏆  Reward Management" styleClass="toolbar-title"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 20 14 20;">
                <TextField fx:id="searchField" promptText="🔍  Search name or type..."
                           prefWidth="280" styleClass="search-field"/>
                <ComboBox fx:id="typeFilter" prefWidth="180"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📥  Export CSV"  onAction="#handleExportCSV" styleClass="btn-ghost"/>
                <Button text="＋  Add Reward"  onAction="#handleAddReward" styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="rewardsTable" styleClass="table-view">
            <BorderPane.margin><Insets top="16" right="20" bottom="0" left="20"/></BorderPane.margin>
            <columns>
                <TableColumn fx:id="iconCol"    text="Icon"         prefWidth="60"  style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="nameCol"    text="Reward Name"  prefWidth="190"/>
                <TableColumn fx:id="typeCol"    text="Type"         prefWidth="150" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="valueCol"   text="Value"        prefWidth="80"  style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="actionsCol" text="Actions"      prefWidth="320" style="-fx-alignment: CENTER;"/>
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="8" style="-fx-padding: 40;">
                    <Label text="🏆" style="-fx-font-size: 40;"/>
                    <Label text="No rewards found." style="-fx-font-size: 15px; -fx-text-fill: #a0aec0;"/>
                </VBox>
            </placeholder>
        </TableView>
    </center>
    <bottom>
        <HBox styleClass="status-bar" style="-fx-padding: 10 20;">
            <Label fx:id="statusLabel" text="" styleClass="status-label"/>
        </HBox>
    </bottom>
</BorderPane>
