<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gamification.GameDashboardController"
            stylesheets="@/css/gamification.css"
            prefWidth="1100" prefHeight="680"
            style="-fx-background-color: #f0f2f8;">

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="0"
              style="-fx-background-color: white;
                     -fx-border-color: transparent #e4e8f0 transparent transparent;
                     -fx-border-width: 0 1 0 0;
                     -fx-pref-width: 200px; -fx-min-width: 200px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 2, 0);">

            <!-- Brand -->
            <VBox style="-fx-background-color: linear-gradient(to right, #3b4fd8, #5b6ef5);
                         -fx-padding: 20 16 16 16;">
                <Label text="🎮  NOVA"
                       style="-fx-text-fill: white; -fx-font-size: 18px;
                              -fx-font-weight: bold;"/>
                <Label text="Gamification"
                       style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 11px;"/>
            </VBox>

            <VBox spacing="2" style="-fx-padding: 12 8;">
                <Button text="🕹  Games" onAction="#showGames" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #4a5568;
                               -fx-font-size: 13px; -fx-padding: 10 14;
                               -fx-alignment: CENTER_LEFT; -fx-cursor: hand;
                               -fx-background-radius: 8; -fx-border-color: transparent;"/>
                <Button text="🏆  Rewards" onAction="#showRewards" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #4a5568;
                               -fx-font-size: 13px; -fx-padding: 10 14;
                               -fx-alignment: CENTER_LEFT; -fx-cursor: hand;
                               -fx-background-radius: 8; -fx-border-color: transparent;"/>
                <Button text="📊  Statistics" onAction="#showStats" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #4a5568;
                               -fx-font-size: 13px; -fx-padding: 10 14;
                               -fx-alignment: CENTER_LEFT; -fx-cursor: hand;
                               -fx-background-radius: 8; -fx-border-color: transparent;"/>
            </VBox>
        </VBox>
    </left>

    <!-- CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f0f2f8;"/>
    </center>

</BorderPane>
