<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f8fafc;"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.UserCourseController">

    <!-- FILTER BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                     -fx-border-width: 0 0 1 0; -fx-padding: 14 40 14 40;">
            <Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
            <TextField fx:id="searchField" promptText="Search courses…" prefWidth="200"
                       style="-fx-background-radius: 20; -fx-padding: 6 14;
                              -fx-border-color: #e2e8f0; -fx-border-radius: 20;"/>
            <ComboBox fx:id="filterDifficulty" prefWidth="140" promptText="All Difficulties"
                      style="-fx-background-radius: 8;"/>
            <ComboBox fx:id="filterCategory"   prefWidth="150" promptText="All Categories"
                      style="-fx-background-radius: 8;"/>
            <ComboBox fx:id="filterStatus"     prefWidth="140" promptText="All Statuses"
                      style="-fx-background-radius: 8;"/>
            <Button text="🔄" onAction="#handleRefresh"
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b;
                           -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statsLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
        </HBox>
    </top>

    <!-- CARD GRID -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox>
                <padding><Insets top="24" right="40" bottom="24" left="40"/></padding>
                <FlowPane fx:id="courseCardsPane" hgap="20" vgap="20" prefWrapLength="900"/>

                <!-- EMPTY STATE -->
                <VBox fx:id="emptyState" alignment="CENTER" spacing="12"
                      style="-fx-padding: 80 0 0 0;" visible="false" managed="false">
                    <Label text="📭" style="-fx-font-size: 48px;"/>
                    <Label text="No courses available"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="Check back later or adjust your filters."
                           style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- STATUS BAR -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              style="-fx-padding: 6 40; -fx-background-color: white;
                     -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>
