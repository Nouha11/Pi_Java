<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f8fafc;"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.UserSessionController">

    <!-- PAGE HEADER -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 40 16 40;">
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="⏱ My Study Sessions"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Your completed study session history"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox style="-fx-padding: 24 40;" spacing="16">
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-border-radius: 12; -fx-border-color: #e2e8f0;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <!-- FILTERS -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 14 20; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <Label text="Burnout:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="filterBurnout" prefWidth="120" promptText="All"
                              style="-fx-background-radius: 8;"/>
                    <Label text="Mood:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="filterMood" prefWidth="110" promptText="All"
                              style="-fx-background-radius: 8;"/>
                    <Label text="Energy:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="filterEnergy" prefWidth="110" promptText="All"
                              style="-fx-background-radius: 8;"/>
                    <Label text="From:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dateFrom" prefWidth="130"/>
                    <Label text="To:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dateTo" prefWidth="130"/>
                    <Button text="🔄" onAction="#handleRefresh"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 12;"/>
                </HBox>

                <!-- TABLE -->
                <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colCourse"   text="Course"         prefWidth="180" minWidth="100"/>
                        <TableColumn fx:id="colPlanning" text="Planning"        prefWidth="180" minWidth="100"/>
                        <TableColumn fx:id="colStarted"  text="Started At"      prefWidth="155" minWidth="100"/>
                        <TableColumn fx:id="colDuration" text="Duration (min)"  prefWidth="115" minWidth="80"/>
                        <TableColumn fx:id="colXP"       text="XP Earned"       prefWidth="90"  minWidth="60"/>
                        <TableColumn fx:id="colBurnout"  text="Burnout Risk"    prefWidth="110" minWidth="80"/>
                        <TableColumn fx:id="colMood"     text="Mood"            prefWidth="90"  minWidth="60"/>
                        <TableColumn fx:id="colEnergy"   text="Energy Level"    prefWidth="100" minWidth="60"/>
                    </columns>
                    <placeholder>
                        <Label text="No study sessions yet. Start one from My Plannings."
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>

                <!-- FOOTER -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-padding: 12 20; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;
                             -fx-background-color: #f8fafc; -fx-background-radius: 0 0 12 12;">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statsLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Label fx:id="statusLabel" text="Ready"
                           style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
