<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f0f2f8;"
            stylesheets="@../../css/study.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.EnrollmentRequestsController">

    <!-- PAGE HEADER -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #dee2e6;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="3">
                    <Label text="📬 Enrollment Requests"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <Label text="Review and manage enrollment requests for your courses"
                           style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <Button text="🔄 Refresh" onAction="#handleRefresh"
                        style="-fx-background-color: #f0f2f8; -fx-text-fill: #546e7a;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;
                               -fx-font-size: 13;"/>
            </HBox>
        </VBox>
    </top>

    <!-- TABLE VIEW -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox spacing="0">
                <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                <!-- TABLE -->
                <TableView fx:id="requestsTable"
                          style="-fx-background-color: white; -fx-background-radius: 10;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="studentNameColumn" text="Student Name" />
                        <TableColumn fx:id="courseNameColumn" text="Course Name" />
                        <TableColumn fx:id="requestedAtColumn" text="Requested At" />
                        <TableColumn fx:id="actionsColumn" text="Actions" sortable="false" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- EMPTY STATE -->
                <VBox fx:id="emptyState" alignment="CENTER" spacing="12"
                      style="-fx-padding: 80 0 0 0; -fx-background-color: white;
                             -fx-background-radius: 10; -fx-border-color: #e2e8f0;
                             -fx-border-radius: 10; -fx-min-height: 400;"
                      visible="false" managed="false">
                    <Label text="📭"  style="-fx-font-size: 48;"/>
                    <Label text="No pending enrollment requests."
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #546e7a;"/>
                    <Label text="When students request to enroll in your courses, they will appear here."
                           style="-fx-font-size: 13; -fx-text-fill: #90a4ae; -fx-wrap-text: true;
                                  -fx-max-width: 400; -fx-text-alignment: center;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- BOTTOM STATUS -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-padding: 6 24; -fx-background-color: white;
                     -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;">
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: #546e7a; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
