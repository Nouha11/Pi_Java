<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="650" prefWidth="530" spacing="0" styleClass="form-pane"
      stylesheets="@../../css/study.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="controllers.studysession.CourseFormController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" styleClass="form-header">
        <padding><Insets bottom="16" left="20" right="20" top="16" /></padding>
        <Label fx:id="formTitle" styleClass="form-title" text="Course" />
    </HBox>

    <!-- GLOBAL ERROR BANNER -->
    <Label fx:id="lblError" managed="true" maxWidth="490" styleClass="error-banner" visible="false" wrapText="true">
        <VBox.margin><Insets left="20" right="20" top="10" /></VBox.margin>
    </Label>

    <!-- SCROLLABLE FIELDS -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color:transparent; -fx-background:transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
        <GridPane hgap="14" style="-fx-background-color:white; -fx-background-radius:8px;                          -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);" vgap="2">
            <padding><Insets bottom="18" left="22" right="22" top="18" /></padding>

            <!-- Row 0-2: Course Name -->
            <Label styleClass="field-label" text="Course Name *" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="0" />
            <TextField fx:id="txtName" maxWidth="Infinity" promptText="e.g. Introduction to Java  (min 3 chars)" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1" />
            <Label fx:id="errName" managed="false" styleClass="field-error" text=" " visible="false" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2" />

            <!-- Row 3-5: Category -->
            <Label styleClass="field-label" text="Category *" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3" />
            <TextField fx:id="txtCategory" maxWidth="Infinity" promptText="e.g. Programming" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4" />
            <Label fx:id="errCategory" managed="false" styleClass="field-error" text=" " visible="false" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="5" />

            <!-- Row 6-8: Difficulty -->
            <Label styleClass="field-label" text="Difficulty *" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <Label styleClass="field-label" text="Status *" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            <ComboBox fx:id="cbDifficulty" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="7" />
            <ComboBox fx:id="cbStatus" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="7" />
            <Label fx:id="errDifficulty" managed="false" styleClass="field-error" text=" " visible="false" GridPane.columnIndex="0" GridPane.rowIndex="8" />
            <Label fx:id="errStatus" managed="false" styleClass="field-error" text=" " visible="false" GridPane.columnIndex="1" GridPane.rowIndex="8" />

            <!-- Row 9-11: Duration | Progress -->
            <Label styleClass="field-label" text="Estimated Duration (min) *" GridPane.columnIndex="0" GridPane.rowIndex="9" />
            <Label styleClass="field-label" text="Progress % (0–100)" GridPane.columnIndex="1" GridPane.rowIndex="9" />
            <TextField fx:id="txtDuration" maxWidth="Infinity" promptText="e.g. 120" GridPane.columnIndex="0" GridPane.rowIndex="10" />
            <TextField fx:id="txtProgress" maxWidth="Infinity" promptText="0" GridPane.columnIndex="1" GridPane.rowIndex="10" />
            <Label fx:id="errDuration" managed="false" styleClass="field-error" text=" " visible="false" GridPane.columnIndex="0" GridPane.rowIndex="11" />
            <Label fx:id="errProgress" managed="false" styleClass="field-error" text=" " visible="false" GridPane.columnIndex="1" GridPane.rowIndex="11" />

            <!-- Row 12-14: Max Students -->
            <Label styleClass="field-label" text="Max Students (optional)" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="12" />
            <TextField fx:id="txtMaxStudents" maxWidth="Infinity" promptText="Leave empty = unlimited" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="13" />
            <Label fx:id="errMaxStudents" managed="false" styleClass="field-error" text=" " visible="false" GridPane.columnIndex="0" GridPane.rowIndex="14" />

            <!-- Row 15-16: Description -->
            <Label styleClass="field-label" text="Description (optional)" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="15" />
            <TextArea fx:id="txtDescription" maxWidth="Infinity" prefRowCount="3" promptText="Brief course description…" wrapText="true" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="16" />

            <!-- Row 17: Published -->
            <CheckBox fx:id="chkPublished" style="-fx-font-weight:bold;" text="✅ Published (visible to students)" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="17">
                <GridPane.margin><Insets top="6" /></GridPane.margin>
            </CheckBox>

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
            </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>
    </ScrollPane>

    <!-- FOOTER BUTTONS -->
    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
        <padding><Insets bottom="14" left="20" right="20" top="12" /></padding>
        <Button cancelButton="true" onAction="#handleCancel" styleClass="btn-ghost" text="Cancel" />
        <Button fx:id="btnSave" defaultButton="true" onAction="#handleSave" styleClass="btn-primary" text="💾 Save Course" />
    </HBox>

</VBox>
