<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f8f9fa;"
            stylesheets="@../../css/study.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.StudySessionController">

    <!-- PAGE HEADER -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #dee2e6;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="📚 Study Sessions"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <Label text="Track your completed study sessions"
                           style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
                </VBox>
                <Button text="➕ New Session" onAction="#handleNew"
                        style="-fx-background-color: #3949ab; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 16;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER: card wrapper -->
    <center>
        <VBox style="-fx-padding: 24;" spacing="16">

            <!-- CARD -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-radius: 8; -fx-border-color: #dee2e6;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

                <!-- CARD HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 14 20; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                    <Label text="All Sessions"
                           style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #212529;"
                           HBox.hgrow="ALWAYS"/>
                    <Label text="Burnout Risk:" style="-fx-text-fill: #546e7a; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="filterBurnout" prefWidth="120" promptText="Burnout Risk"/>
                    <Label text="Mood:" style="-fx-text-fill: #546e7a; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="filterMood" prefWidth="110" promptText="Mood"/>
                    <Label text="Energy:" style="-fx-text-fill: #546e7a; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="filterEnergy" prefWidth="110" promptText="Energy"/>
                    <Label text="From:" style="-fx-text-fill: #546e7a; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dateFrom" prefWidth="130"/>
                    <Label text="To:" style="-fx-text-fill: #546e7a; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dateTo" prefWidth="130"/>
                    <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="btn-ghost"/>
                </HBox>

                <!-- TABLE -->
                <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS" styleClass="data-table"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colCourse"   text="Course"          prefWidth="180" minWidth="100"/>
                        <TableColumn fx:id="colPlanning" text="Planning"         prefWidth="180" minWidth="100"/>
                        <TableColumn fx:id="colStarted"  text="Started At"       prefWidth="155" minWidth="100"/>
                        <TableColumn fx:id="colDuration" text="Duration (min)"   prefWidth="115" minWidth="80"/>
                        <TableColumn fx:id="colXP"       text="XP Earned"        prefWidth="90"  minWidth="60"/>
                        <TableColumn fx:id="colBurnout"  text="Burnout Risk"     prefWidth="110" minWidth="80"/>
                        <TableColumn fx:id="colMood"     text="Mood"             prefWidth="90"  minWidth="60"/>
                        <TableColumn fx:id="colEnergy"   text="Energy Level"     prefWidth="100" minWidth="60"/>
                    </columns>
                    <placeholder>
                        <Label text="No study sessions yet. Start a session from the Plannings tab."
                               style="-fx-text-fill: #90a4ae; -fx-font-size: 13;"/>
                    </placeholder>
                </TableView>

                <!-- CARD FOOTER -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-padding: 12 20; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;
                             -fx-background-color: #f8f9fa; -fx-background-radius: 0 0 8 8;">
                    <Button text="✏ Edit"        styleClass="btn-secondary" onAction="#handleEdit"/>
                    <Button text="🗑 Delete"      styleClass="btn-danger"    onAction="#handleDelete"/>
                    <Button text="📊 Statistics"  styleClass="btn-stats"     onAction="#handleStats"/>
                    <Label fx:id="statsLabel" styleClass="stats-label" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" text="Ready"
                           style="-fx-text-fill: #546e7a; -fx-font-size: 11;"/>
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>
