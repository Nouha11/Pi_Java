<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/17.0.12"
           fx:controller="controllers.studysession.AiStudyAssistantController"
           stylesheets="@../../css/study.css"
           pickOnBounds="false">

    <!-- ══════════════════════════════════════════════════════════
         ANCHOR PANE — positions floating button and chat panel
         bottom-right of the overlay
         ══════════════════════════════════════════════════════════ -->
    <AnchorPane pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">

        <!-- ── Floating Action Button (visible only for ROLE_STUDENT) ── -->
        <Button fx:id="btnFloatingAi"
                text="🤖"
                onAction="#handleFloatingButtonClick"
                AnchorPane.bottomAnchor="24"
                AnchorPane.rightAnchor="24"
                style="-fx-background-color: #4A90D9;
                       -fx-text-fill: white;
                       -fx-font-size: 22px;
                       -fx-background-radius: 50;
                       -fx-min-width: 56;
                       -fx-min-height: 56;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10, 0, 0, 4);"/>

        <!-- ══════════════════════════════════════════════════════
             CHAT PANEL — initially hidden, shown on FAB click
             ══════════════════════════════════════════════════════ -->
        <VBox fx:id="chatPanel"
              minHeight="400" minWidth="320"
              prefWidth="360"
              maxHeight="600"
              visible="false" managed="false"
              AnchorPane.bottomAnchor="24"
              AnchorPane.rightAnchor="24"
              style="-fx-background-color: #1E1E1E;
                     -fx-background-radius: 16;
                     -fx-border-color: #333333;
                     -fx-border-radius: 16;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 0, 6);">

            <!-- ── Chat Panel Header ── -->
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-background-color: #2D2D2D;
                         -fx-background-radius: 16 16 0 0;
                         -fx-padding: 10 12;">
                <Label text="🤖"
                       style="-fx-font-size: 16px; -fx-text-fill: #4A90D9;"/>
                <Label fx:id="lblChatCourseHeader"
                       text="AI Study Assistant"
                       HBox.hgrow="ALWAYS"
                       style="-fx-text-fill: white;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-font-family: 'Segoe UI', Arial, sans-serif;"/>
                <Button fx:id="btnClearHistory"
                        text="🗑"
                        onAction="#handleClearHistory"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #94a3b8;
                               -fx-font-size: 14px;
                               -fx-cursor: hand;
                               -fx-padding: 2 6;
                               -fx-background-radius: 6;"/>
                <Button fx:id="btnMinimize"
                        text="—"
                        onAction="#handleMinimize"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #94a3b8;
                               -fx-font-size: 14px;
                               -fx-cursor: hand;
                               -fx-padding: 2 6;
                               -fx-background-radius: 6;"/>
                <Button fx:id="btnClose"
                        text="✕"
                        onAction="#handleClose"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #94a3b8;
                               -fx-font-size: 14px;
                               -fx-cursor: hand;
                               -fx-padding: 2 6;
                               -fx-background-radius: 6;"/>
            </HBox>

            <!-- ── Quick Prompt Suggestions ── -->
            <ScrollPane fitToWidth="false" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                        prefHeight="42"
                        minHeight="42"
                        style="-fx-background-color: #252525; -fx-background: #252525;
                               -fx-border-color: transparent; -fx-padding: 0;">
                <HBox fx:id="hboxQuickPrompts" spacing="6" alignment="CENTER_LEFT"
                      style="-fx-padding: 6 8;"/>
            </ScrollPane>

            <!-- ── Message List ── -->
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #1E1E1E;
                               -fx-background: #1E1E1E;
                               -fx-border-color: transparent;">
                <VBox fx:id="vboxMessages"
                      spacing="8"
                      fillWidth="true"
                      style="-fx-padding: 12 8; -fx-background-color: #1E1E1E;"/>
            </ScrollPane>

            <!-- ── Typing Indicator ── -->
            <HBox fx:id="typingIndicator"
                  alignment="CENTER_LEFT"
                  spacing="4"
                  visible="false" managed="false"
                  style="-fx-padding: 4 16;">
                <Label text="•"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 20px;"/>
                <Label text="•"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 20px;"/>
                <Label text="•"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 20px;"/>
            </HBox>

            <!-- ── Input Area ── -->
            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #2D2D2D;
                         -fx-background-radius: 0 0 16 16;
                         -fx-padding: 10 12;">
                <TextField fx:id="txtInput"
                           promptText="Ask anything about this course…"
                           onAction="#handleSend"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #3A3A3A;
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: #64748b;
                                  -fx-background-radius: 20;
                                  -fx-padding: 8 14;
                                  -fx-font-size: 12px;
                                  -fx-border-color: #444444;
                                  -fx-border-radius: 20;
                                  -fx-border-width: 1;"/>
                <Button fx:id="btnSend"
                        text="Send"
                        onAction="#handleSend"
                        style="-fx-background-color: #4A90D9;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 12px;
                               -fx-background-radius: 20;
                               -fx-padding: 8 16;
                               -fx-cursor: hand;"/>
            </HBox>

        </VBox>

    </AnchorPane>

</StackPane>
