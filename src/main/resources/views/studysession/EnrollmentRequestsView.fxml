<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f0f2f8;"
            stylesheets="@../../css/study.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.EnrollmentRequestsController">

    <!-- PAGE HEADER -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #dee2e6;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="3">
                    <Label text="📬 Enrollment Requests"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <Label text="Review and manage student enrollment requests for your courses"
                           style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <Button text="🔄 Refresh" onAction="#handleRefresh"
                        style="-fx-background-color: #f0f2f8; -fx-text-fill: #546e7a;
                               -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 5 12;
                               -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- TABLE VIEW -->
    <center>
        <VBox spacing="0" VBox.vgrow="ALWAYS">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <TableView fx:id="requestsTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="studentNameColumn" text="Student" prefWidth="180" />
                    <TableColumn fx:id="courseNameColumn" text="Course" prefWidth="220" />
                    <TableColumn fx:id="requestedAtColumn" text="Requested At" prefWidth="150" />
                    <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="180" />
                </columns>
            </TableView>

            <!-- EMPTY STATE -->
            <VBox fx:id="emptyState" alignment="CENTER" spacing="12"
                  style="-fx-padding: 80 0 0 0;" visible="false" managed="false">
                <Label text="✅"  style="-fx-font-size: 48;"/>
                <Label text="No pending enrollment requests"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #546e7a;"/>
                <Label text="All enrollment requests have been processed."
                       style="-fx-font-size: 13; -fx-text-fill: #90a4ae;"/>
            </VBox>
        </VBox>
    </center>

    <!-- BOTTOM STATUS -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-padding: 6 24; -fx-background-color: white;
                     -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;">
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: #546e7a; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
