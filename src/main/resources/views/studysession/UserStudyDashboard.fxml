<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.UserStudyDashboardController"
            style="-fx-background-color: #f8fafc;">

    <stylesheets>
        <URL value="@../../css/app.css"/>
    </stylesheets>

    <!-- ── PAGE HEADER ── -->
    <top>
        <VBox style="-fx-background-color: white;
                     -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;
                     -fx-padding: 20 40 0 40;">

            <!-- Title row -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="📚 Study Sessions"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStats"
                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            </HBox>

            <!-- Tab bar -->
            <HBox spacing="4" style="-fx-padding: 12 0 0 0;">
                <Button fx:id="tabCourses"   text="📘 Courses"       onAction="#showCourses"
                        styleClass="nav-btn, nav-btn-active"/>
                <Button fx:id="tabPlannings" text="📅 Calendar"      onAction="#showPlannings"
                        styleClass="nav-btn"/>
                <Button fx:id="tabMyPlannings" text="🗒 My Plannings" onAction="#showMyPlannings"
                        styleClass="nav-btn"/>
                <Button fx:id="tabSessions"  text="⏱ My Sessions"   onAction="#showSessions"
                        styleClass="nav-btn"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── CONTENT AREA ── -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f8fafc;"/>
    </center>

</BorderPane>
