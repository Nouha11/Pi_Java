<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.studysession.StudySessionFormController"
      spacing="0" styleClass="form-pane" prefWidth="500" prefHeight="620">

    <!-- HEADER -->
    <HBox styleClass="form-header" alignment="CENTER_LEFT">
        <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
        <Label fx:id="formTitle" text="Study Session" styleClass="form-title"/>
    </HBox>

    <!-- GLOBAL ERROR -->
    <Label fx:id="lblError" styleClass="error-banner" wrapText="true"
           visible="false" managed="false" maxWidth="460">
        <VBox.margin><Insets left="20" right="20" top="10"/></VBox.margin>
    </Label>

    <!-- AUTO-CALC BANNER -->
    <Label fx:id="lblAutoCalc"
           text="⚡ Enter duration to auto-calculate XP and burnout risk"
           style="-fx-background-color:#e8f5e9; -fx-text-fill:#2e7d32;
                  -fx-background-radius:6px; -fx-padding:8 12 8 12;
                  -fx-font-size:12px; -fx-font-weight:bold;"
           wrapText="true" maxWidth="460">
        <VBox.margin><Insets left="20" right="20" top="8"/></VBox.margin>
    </Label>

    <!-- FIELDS -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent; -fx-background:transparent;">
        <GridPane hgap="14" vgap="2"
                  style="-fx-background-color:white; -fx-background-radius:8px;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <padding><Insets top="18" right="22" bottom="18" left="22"/></padding>

            <!-- Planning -->
            <Label text="Planning Session *" styleClass="field-label"
                   GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
            <ComboBox fx:id="cbPlanning" maxWidth="Infinity"
                      GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
            <Label fx:id="errPlanning" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2"/>

            <!-- Duration | Actual Duration -->
            <Label text="Planned Duration (min) *" styleClass="field-label"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Label text="Actual Duration (min)" styleClass="field-label"
                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <TextField fx:id="txtDuration" promptText="e.g. 60"
                       GridPane.rowIndex="4" GridPane.columnIndex="0" maxWidth="Infinity"/>
            <TextField fx:id="txtActualDuration" promptText="Leave empty = same as planned"
                       GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label fx:id="errDuration" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <Label fx:id="errActualDuration" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <!-- XP | Burnout (read-only, auto-calculated) -->
            <Label text="XP Earned (auto)" styleClass="field-label"
                   GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <Label text="Burnout Risk (auto)" styleClass="field-label"
                   GridPane.rowIndex="6" GridPane.columnIndex="1"/>
            <TextField fx:id="txtXpEarned" editable="false" promptText="Auto-calculated"
                       style="-fx-background-color:#f5f5f5; -fx-text-fill:#546e7a;"
                       GridPane.rowIndex="7" GridPane.columnIndex="0" maxWidth="Infinity"/>
            <TextField fx:id="txtBurnoutRisk" editable="false" promptText="Auto-calculated"
                       style="-fx-background-color:#f5f5f5; -fx-text-fill:#546e7a;"
                       GridPane.rowIndex="7" GridPane.columnIndex="1" maxWidth="Infinity"/>

            <!-- Mood | Energy -->
            <Label text="Mood" styleClass="field-label"
                   GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <Label text="Energy Level" styleClass="field-label"
                   GridPane.rowIndex="8" GridPane.columnIndex="1"/>
            <ComboBox fx:id="cbMood" maxWidth="Infinity"
                      GridPane.rowIndex="9" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cbEnergyLevel" maxWidth="Infinity"
                      GridPane.rowIndex="9" GridPane.columnIndex="1"/>

            <!-- Break Duration | Break Count -->
            <Label text="Break Duration (min)" styleClass="field-label"
                   GridPane.rowIndex="10" GridPane.columnIndex="0"/>
            <Label text="Break Count" styleClass="field-label"
                   GridPane.rowIndex="10" GridPane.columnIndex="1"/>
            <TextField fx:id="txtBreakDuration" promptText="Optional"
                       GridPane.rowIndex="11" GridPane.columnIndex="0" maxWidth="Infinity"/>
            <TextField fx:id="txtBreakCount" promptText="Optional"
                       GridPane.rowIndex="11" GridPane.columnIndex="1" maxWidth="Infinity"/>

            <!-- Pomodoro Count -->
            <Label text="Pomodoro Count" styleClass="field-label"
                   GridPane.rowIndex="12" GridPane.columnIndex="0"/>
            <TextField fx:id="txtPomodoroCount" promptText="Optional"
                       GridPane.rowIndex="13" GridPane.columnIndex="0" maxWidth="Infinity"/>

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>
        </GridPane>
    </ScrollPane>

    <!-- FOOTER -->
    <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
        <padding><Insets top="12" right="20" bottom="14" left="20"/></padding>
        <Button text="Cancel" styleClass="btn-ghost" onAction="#handleCancel" cancelButton="true"/>
        <Button fx:id="btnSave" text="💾 Save Session" styleClass="btn-primary"
                onAction="#handleSave" defaultButton="true"/>
    </HBox>

</VBox>
