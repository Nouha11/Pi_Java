<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<VBox spacing="0" styleClass="form-pane" prefWidth="480" prefHeight="560"
      stylesheets="@../../css/study.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="controllers.studysession.PlanningFormController">



    <!-- HEADER -->
    <HBox styleClass="form-header" alignment="CENTER_LEFT">
        <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
        <VBox spacing="3">
            <Label fx:id="formTitle" text="Planning" styleClass="form-title"/>
            <Label fx:id="lblCourseName" text="Course: —"
                   style="-fx-text-fill:#b0bec5; -fx-font-size:12px;"/>
        </VBox>
    </HBox>

    <!-- GLOBAL ERROR -->
    <Label fx:id="lblError" styleClass="error-banner" wrapText="true"
           visible="false" managed="true" maxWidth="440">
        <VBox.margin><Insets left="20" right="20" top="10"/></VBox.margin>
    </Label>

    <!-- FIELDS -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent; -fx-background:transparent;">
        <GridPane hgap="14" vgap="2"
                  style="-fx-background-color:white; -fx-background-radius:8px;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <padding><Insets top="18" right="22" bottom="18" left="22"/></padding>

            <!-- Title -->
            <Label text="Session Title *" styleClass="field-label"
                   GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
            <TextField fx:id="txtTitle" promptText="e.g. Chapter 3 Review  (min 3 chars)"
                       GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2"
                       maxWidth="Infinity"/>
            <Label fx:id="errTitle" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2"/>

            <!-- Date | Time -->
            <Label text="Scheduled Date *" styleClass="field-label"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Label text="Scheduled Time * (HH:mm)" styleClass="field-label"
                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <DatePicker fx:id="dpDate" maxWidth="Infinity"
                        GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="txtTime" promptText="14:30"
                       GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label fx:id="errDate" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <Label fx:id="errTime" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <!-- Duration | Status -->
            <Label text="Planned Duration (min) *" styleClass="field-label"
                   GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <Label text="Status *" styleClass="field-label"
                   GridPane.rowIndex="6" GridPane.columnIndex="1"/>
            <TextField fx:id="txtDuration" promptText="e.g. 60"
                       GridPane.rowIndex="7" GridPane.columnIndex="0" maxWidth="Infinity"/>
            <ComboBox fx:id="cbStatus" maxWidth="Infinity"
                      GridPane.rowIndex="7" GridPane.columnIndex="1"/>
            <Label fx:id="errDuration" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <Label fx:id="errStatus" styleClass="field-error" text=" "
                   visible="false" managed="false"
                   GridPane.rowIndex="8" GridPane.columnIndex="1"/>

            <!-- Reminder -->
            <CheckBox fx:id="chkReminder" text="🔔 Enable reminder for this session"
                      style="-fx-font-weight:bold;"
                      GridPane.rowIndex="9" GridPane.columnIndex="0" GridPane.columnSpan="2">
                <GridPane.margin><Insets top="10"/></GridPane.margin>
            </CheckBox>

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>
        </GridPane>
    </ScrollPane>

    <!-- FOOTER -->
    <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
        <padding><Insets top="12" right="20" bottom="14" left="20"/></padding>
        <Button text="Cancel" styleClass="btn-ghost" onAction="#handleCancel" cancelButton="true"/>
        <Button fx:id="btnSave" text="💾 Save Planning" styleClass="btn-primary"
                onAction="#handleSave" defaultButton="true"/>
    </HBox>

</VBox>
