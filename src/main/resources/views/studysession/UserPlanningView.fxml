<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #f8fafc; -fx-background: #f8fafc; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.studysession.UserPlanningController">

    <VBox spacing="25" style="-fx-padding: 30;">

        <!-- PAGE HEADER -->
        <VBox spacing="4">
            <Label text="My Planning Sessions"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
            <Label text="Schedule and track your upcoming study sessions"
                   style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
        </VBox>

        <!-- FILTER BAR -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-padding: 16 20;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
            <TextField fx:id="searchField" promptText="🔍  Search by title…" prefWidth="220"
                       style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                              -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
            <ComboBox fx:id="filterStatus" prefWidth="140" promptText="All Statuses"
                      style="-fx-background-radius: 8;"/>
            <ComboBox fx:id="filterCourse" prefWidth="180" promptText="All Courses"
                      style="-fx-background-radius: 8;"/>
            <Label text="From:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
            <DatePicker fx:id="dateFrom" prefWidth="130"/>
            <Label text="To:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
            <DatePicker fx:id="dateTo" prefWidth="130"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔄 Refresh" onAction="#handleRefresh"
                    style="-fx-background-color: #f8fafc; -fx-text-fill: #334155;
                           -fx-font-weight: bold; -fx-padding: 8 16;
                           -fx-background-radius: 8; -fx-border-color: #e2e8f0;
                           -fx-border-radius: 8; -fx-cursor: hand;"/>
            <Button text="➕ Schedule Session" onAction="#handleNew"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 14px;
                           -fx-padding: 8 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>

        <!-- MAIN PANEL -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">

            <!-- Panel header -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="My Planning Sessions"
                           style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="statsLabel" text="Loading…"
                           style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                </VBox>
                <HBox spacing="8"/>
            </HBox>

            <!-- Cards list -->
            <ScrollPane fitToWidth="true" prefHeight="520"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox fx:id="cardsContainer" spacing="8" style="-fx-padding: 12;"/>
            </ScrollPane>

            <!-- Footer status -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding: 12 24; -fx-border-color: #f1f5f9; -fx-border-width: 1 0 0 0;">
                <Label fx:id="statusLabel" text="Ready"
                       style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>

        <Region prefHeight="20"/>
    </VBox>
</ScrollPane>
