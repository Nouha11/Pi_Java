<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f8fafc;"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.UserPlanningController">

    <!-- PAGE HEADER -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 40 16 40;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="📅 My Planning Sessions"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Schedule and track your upcoming study sessions"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                </VBox>
                <Button text="➕ Schedule Session" onAction="#handleNew"
                        style="-fx-background-color: #4f46e5; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 9 18;
                               -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox style="-fx-padding: 24 40;" spacing="16">
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-border-radius: 12; -fx-border-color: #e2e8f0;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <!-- CARD HEADER / FILTERS -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 14 20; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <Label text="🔍" style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    <TextField fx:id="searchField" promptText="Search by title…" prefWidth="180"
                               style="-fx-background-radius: 8; -fx-border-color: #e2e8f0;
                                      -fx-border-radius: 8; -fx-padding: 5 10;"/>
                    <Label text="Status:" style="-fx-text-fill: #0f172a; -fx-font-size: 13px;"/>
                    <ComboBox fx:id="filterStatus" prefWidth="130" promptText="All"
                              style="-fx-background-radius: 8;"/>
                    <Label text="Course:" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    <ComboBox fx:id="filterCourse" prefWidth="180" promptText="All"
                              style="-fx-background-radius: 8;"/>
                    <Label text="From:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dateFrom" prefWidth="130"/>
                    <Label text="To:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dateTo" prefWidth="130"/>
                    <Button text="🔄" onAction="#handleRefresh"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b;
                                   -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 12;"/>
                </HBox>

                <!-- TABLE -->
                <TableView fx:id="planningTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colCourse"   text="Course"          prefWidth="180" minWidth="100"/>
                        <TableColumn fx:id="colTitle"    text="Title"           prefWidth="200" minWidth="100"/>
                        <TableColumn fx:id="colDate"     text="Date"            prefWidth="110" minWidth="80"/>
                        <TableColumn fx:id="colTime"     text="Time"            prefWidth="80"  minWidth="60"/>
                        <TableColumn fx:id="colDuration" text="Duration (min)"  prefWidth="115" minWidth="80"/>
                        <TableColumn fx:id="colStatus"   text="Status"          prefWidth="120" minWidth="80"/>
                        <TableColumn fx:id="colReminder" text="Reminder"        prefWidth="80"  minWidth="60"/>
                    </columns>
                    <placeholder>
                        <Label text="No planning sessions yet. Click ➕ to schedule one."
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>

                <!-- CARD FOOTER — user-only actions -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-padding: 12 20; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;
                             -fx-background-color: #f8fafc; -fx-background-radius: 0 0 12 12;">
                    <Button text="✅ Mark Complete" onAction="#handleMarkComplete"
                            style="-fx-background-color: #dcfce7; -fx-text-fill: #16a34a;
                                   -fx-font-weight: bold; -fx-background-radius: 8;
                                   -fx-cursor: hand; -fx-padding: 7 14;"/>
                    <Button text="↩ Mark Incomplete" onAction="#handleMarkIncomplete"
                            style="-fx-background-color: #fef9c3; -fx-text-fill: #854d0e;
                                   -fx-font-weight: bold; -fx-background-radius: 8;
                                   -fx-cursor: hand; -fx-padding: 7 14;"/>
                    <Button text="▶ Start Session" onAction="#handleStartSession"
                            style="-fx-background-color: #e0e7ff; -fx-text-fill: #4f46e5;
                                   -fx-font-weight: bold; -fx-background-radius: 8;
                                   -fx-cursor: hand; -fx-padding: 7 14;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statsLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Label fx:id="statusLabel" text="Ready"
                           style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
