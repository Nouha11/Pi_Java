<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" prefWidth="900" prefHeight="600"
      style="-fx-background-color: #f8fafc;"
      stylesheets="@../../css/study.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="controllers.studysession.CourseDetailController">

    <!-- HEADER -->
    <VBox style="-fx-background-color: white; -fx-border-color: #f1f5f9;
                 -fx-border-width: 0 0 1 0; -fx-padding: 20 24;">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox HBox.hgrow="ALWAYS" spacing="6">
                <Label fx:id="lblCourseName" text="—"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label fx:id="lblCategory"
                           style="-fx-background-color: #dbeafe; -fx-text-fill: #2563eb;
                                  -fx-font-weight: bold; -fx-padding: 3 10;
                                  -fx-background-radius: 20; -fx-font-size: 12px;" text="—"/>
                    <Label fx:id="lblDifficulty"
                           style="-fx-background-color: #ede9fe; -fx-text-fill: #7c3aed;
                                  -fx-font-weight: bold; -fx-padding: 3 10;
                                  -fx-background-radius: 20; -fx-font-size: 12px;" text="—"/>
                    <Label fx:id="lblStatus"
                           style="-fx-background-color: #dcfce7; -fx-text-fill: #16a34a;
                                  -fx-font-weight: bold; -fx-padding: 3 10;
                                  -fx-background-radius: 20; -fx-font-size: 12px;" text="—"/>
                    <Label fx:id="lblPublished"
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="—"/>
                </HBox>
            </VBox>
            <VBox alignment="CENTER_RIGHT" spacing="4">
                <Label fx:id="lblDuration"  style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="—"/>
                <Label fx:id="lblProgress"  style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="—"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- DESCRIPTION -->
    <VBox style="-fx-background-color: white; -fx-border-color: #f1f5f9;
                 -fx-border-width: 0 0 1 0; -fx-padding: 14 24;">
        <Label text="About this course"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
        <TextArea fx:id="txtDescription" editable="false" wrapText="true" prefRowCount="3"
                  style="-fx-background-color: transparent; -fx-border-color: transparent;
                         -fx-font-size: 13px; -fx-text-fill: #334155;"/>
    </VBox>

    <!-- PLANNINGS PANEL -->
    <VBox VBox.vgrow="ALWAYS" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 0;">

        <!-- Panel header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 16 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Planning Sessions"
                       style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0f172a;"/>
                <Label fx:id="lblPlanCount" text="0 sessions"
                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            </VBox>
            <Button text="➕ Add Planning Session" onAction="#handleAddPlanning"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 16;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>

        <!-- Cards -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <VBox fx:id="cardsContainer" spacing="8" style="-fx-padding: 12;"/>
        </ScrollPane>
    </VBox>

</VBox>
