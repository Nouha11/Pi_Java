<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #f0f2f8;"
            stylesheets="@../../css/study.css"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12"
            fx:controller="controllers.studysession.AdminEnrollmentController">

    <!-- PAGE HEADER -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #dee2e6;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="3">
                    <Label text="📋 Enrollment Management"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <Label text="Monitor and manage all student enrollments across the platform"
                           style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <Button text="🔄 Refresh" onAction="#handleRefresh"
                        style="-fx-background-color: #f0f2f8; -fx-text-fill: #546e7a;
                               -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 5 12;
                               -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <VBox spacing="0" VBox.vgrow="ALWAYS">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- SUMMARY CARDS -->
            <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
                <!-- Total Enrollments Card -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Total Enrollments" styleClass="stat-card-label"/>
                    <Label fx:id="lblTotalEnrollments" text="0" styleClass="stat-card-value"/>
                </VBox>

                <!-- Pending Card -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Pending" styleClass="stat-card-label"/>
                    <Label fx:id="lblPendingCount" text="0" styleClass="stat-card-value"
                           style="-fx-text-fill: #f57f17;"/>
                </VBox>

                <!-- Accepted Card -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Accepted" styleClass="stat-card-label"/>
                    <Label fx:id="lblAcceptedCount" text="0" styleClass="stat-card-value"
                           style="-fx-text-fill: #2e7d32;"/>
                </VBox>

                <!-- Rejected Card -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Rejected" styleClass="stat-card-label"/>
                    <Label fx:id="lblRejectedCount" text="0" styleClass="stat-card-value"
                           style="-fx-text-fill: #c62828;"/>
                </VBox>
            </HBox>

            <!-- FILTER CONTROLS -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 16 0;">
                <Label text="🔍" style="-fx-font-size: 14; -fx-text-fill: #546e7a;"/>
                <TextField fx:id="searchField"
                           promptText="Search by course name…"
                           prefWidth="250"
                           style="-fx-background-radius: 20; -fx-padding: 6 14;"/>
                <ComboBox fx:id="filterStatus" prefWidth="150" promptText="All Statuses"
                          style="-fx-background-radius: 6;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- TABLE VIEW -->
            <TableView fx:id="enrollmentsTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colStudent" text="Student" prefWidth="150" />
                    <TableColumn fx:id="colCourse" text="Course" prefWidth="200" />
                    <TableColumn fx:id="colCreator" text="Provider" prefWidth="150" />
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                    <TableColumn fx:id="colDate" text="Requested At" prefWidth="140" />
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="180" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- BOTTOM STATUS -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-padding: 6 24; -fx-background-color: white;
                     -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;">
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: #546e7a; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
