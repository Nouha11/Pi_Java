<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1050.0" spacing="30.0" style="-fx-background-color: #f8fafc; -fx-padding: 40;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.forum.ForumStatsController">
    <children>
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Forum Analytics" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Track community engagement and discussion trends." />
            </children>
        </VBox>

        <HBox spacing="20.0">
            <children>
                <VBox alignment="CENTER" prefHeight="150.0" prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <children>
                        <Label style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" text="💬" />
                        <Label fx:id="totalPostsLabel" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="0" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Total Discussions" />
                    </children>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Posts per Space" />
                        <BarChart fx:id="spacesChart" legendVisible="false" prefHeight="350.0">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT" />
                            </yAxis>
                        </BarChart>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>