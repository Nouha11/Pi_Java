<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1050.0" spacing="20.0" style="-fx-background-color: #f8fafc; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.forum.AdminForumController">
    <children>
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Forum Management" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Manage all student discussions, moderate content, and lock threads." />
            </children>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;" VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="postTable" style="-fx-background-color: transparent; -fx-control-inner-background: white; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="titleCol" prefWidth="300.0" text="Post Title" />
                        <TableColumn fx:id="authorCol" prefWidth="150.0" text="Author" />
                        <TableColumn fx:id="spaceCol" prefWidth="120.0" text="Space" />
                        <TableColumn fx:id="upvotesCol" prefWidth="80.0" text="Upvotes" />
                        <TableColumn fx:id="statusCol" prefWidth="100.0" text="Status" />
                        <TableColumn fx:id="actionsCol" prefWidth="180.0" text="Actions" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>