<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1050.0" spacing="20.0" style="-fx-background-color: #f8fafc; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.forum.AdminForumController">
    <children>
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Forum Management" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Manage all student discussions, moderate content, and lock threads." />
            </children>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 4);" VBox.vgrow="ALWAYS">

            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f1f5f9; -fx-padding: 12 20; -fx-background-radius: 8 8 0 0; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                <Label prefWidth="350.0" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="POST DETAILS" />
                <Label prefWidth="120.0" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="SPACE" />
                <Label prefWidth="80.0" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="UPVOTES" />
                <Label prefWidth="100.0" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="STATUS" />
                <Region HBox.hgrow="ALWAYS" />
                <Label alignment="CENTER" prefWidth="160.0" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13px;" text="ACTIONS" />
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="postsContainer" spacing="0" />
                </content>
            </ScrollPane>

        </VBox>
    </children>
</VBox>