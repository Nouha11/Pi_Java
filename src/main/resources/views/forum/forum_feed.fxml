<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.forum.ForumFeedController">

    <VBox minWidth="220.0" prefWidth="220.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 1 0 0;">
        <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
        </padding>

        <VBox spacing="4.0">
            <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" text="FEEDS" />
            <HBox fx:id="btnHome" alignment="CENTER_LEFT" onMouseClicked="#handleShowAllPosts" spacing="10.0" style="-fx-padding: 8 12; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: #eff6ff;">
                <Label style="-fx-font-size: 16px;" text="🏠" />
                <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 13px;" text="Home" />
            </HBox>
            <HBox fx:id="btnPopular" alignment="CENTER_LEFT" onMouseClicked="#handleShowPopular" spacing="10.0" style="-fx-padding: 8 12; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: transparent;">
                <Label style="-fx-font-size: 16px;" text="🔥" />
                <Label style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 13px;" text="Popular" />
            </HBox>
            <HBox fx:id="btnSaved" alignment="CENTER_LEFT" onMouseClicked="#handleShowSavedPosts" spacing="10.0" style="-fx-padding: 8 12; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: transparent;">
                <Label style="-fx-font-size: 16px;" text="🔖" />
                <Label style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 13px;" text="Saved" />
            </HBox>
            <HBox fx:id="btnSandbox" alignment="CENTER_LEFT" onMouseClicked="#handleOpenSandbox" spacing="10.0" style="-fx-padding: 8 12; -fx-background-radius: 6; -fx-cursor: hand; -fx-background-color: transparent;">
                <Label style="-fx-font-size: 16px;" text="💻" />
                <Label style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 13px;" text="Sandbox" />
            </HBox>
        </VBox>

        <VBox spacing="4.0">
            <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" text="STUDY SPACES" />
            <VBox fx:id="spacesContainer" spacing="2.0" />
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <VBox spacing="4.0">
            <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" text="TRENDING" />
            <VBox fx:id="trendingTagsContainer" spacing="2.0" />
        </VBox>
    </VBox>

    <ScrollPane fx:id="mainScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f8fafc; -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
        <content>
            <VBox alignment="TOP_CENTER" spacing="12.0">
                <padding>
                    <Insets bottom="30.0" left="20.0" right="20.0" top="15.0" />
                </padding>

                <VBox maxWidth="900.0" spacing="12.0">

                    <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10 15;">
                        <Circle fx:id="bannerIcon" fill="#2563eb" radius="16.0" />
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="lblBannerTitle" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="NOVA / Home" />
                            <Label fx:id="lblBannerDesc" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="All discussions across all spaces." />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleGoToCreatePost" prefHeight="45.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-cursor: hand; -fx-padding: 5 15;">
                        <Label alignment="CENTER" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 50; -fx-font-size: 14px;" text="👤" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" text="Create Post..." />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="10.0">
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 16px;" text="📷" />
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 16px;" text="🔗" />
                        </HBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 8 15;">

                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <Label fx:id="btnSortHot" onMouseClicked="#handleSortHot" style="-fx-padding: 6 12; -fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-color: #eff6ff; -fx-background-radius: 6;" text="🔥 Hot" />
                            <Label fx:id="btnSortNew" onMouseClicked="#handleSortNew" style="-fx-padding: 6 12; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 6;" text="✨ New" />
                            <Label fx:id="btnSortTop" onMouseClicked="#handleSortTop" style="-fx-padding: 6 12; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 6;" text="📈 Top" />
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-border-color: #e2e8f0; -fx-border-radius: 50; -fx-padding: 2 15;">
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="🔍" />
                            <TextField fx:id="searchField" promptText="Search discussions..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-pref-width: 220; -fx-padding: 6 0; -fx-font-size: 13px;" />
                        </HBox>
                    </HBox>

                    <VBox fx:id="postsContainer" spacing="10.0" />

                    <HBox fx:id="paginationContainer" alignment="CENTER" spacing="6.0" />
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</HBox>