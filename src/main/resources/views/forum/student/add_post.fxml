<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="700.0" style="-fx-background-color: white; -fx-background-radius: 12;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.forum.AddPostController">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" spacing="15.0">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>
                <Label fx:id="mainTitleLabel" text="Create a New Post" style="-fx-text-fill: #0f172a; -fx-font-weight: 900; -fx-font-size: 26px;">
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Title:" style="-fx-text-fill: #475569; -fx-font-weight: bold;" />
                                <TextField fx:id="titleField" promptText="Enter post title..." style="-fx-pref-height: 40; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6;" />
                                <Label fx:id="titleError" text="Title must be at least 5 characters." style="-fx-text-fill: #ef4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false"/>
                            </children>
                        </VBox>
                        <VBox prefWidth="220.0" spacing="5.0">
                            <children>
                                <Label text="Space:" style="-fx-text-fill: #475569; -fx-font-weight: bold;" />
                                <ComboBox fx:id="spaceCombo" maxWidth="1.7976931348623157E308" promptText="Select Space" style="-fx-pref-height: 40; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6;" />
                                <Label fx:id="spaceError" text="Please select a space." style="-fx-text-fill: #ef4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Tags (comma separated):" style="-fx-text-fill: #475569; -fx-font-weight: bold;" />
                                <TextField fx:id="tagsField" promptText="e.g. Science, Exams" style="-fx-pref-height: 40; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6;" />
                            </children>
                        </VBox>
                        <VBox prefWidth="220.0" spacing="5.0">
                            <children>
                                <Label text="URL Link:" style="-fx-text-fill: #475569; -fx-font-weight: bold;" />
                                <TextField fx:id="linkField" promptText="https://..." style="-fx-pref-height: 40; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="BOTTOM_LEFT" spacing="12.0">
                    <children>
                        <Label text="Content:" style="-fx-text-fill: #475569; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="enhanceButton" mnemonicParsing="false" onAction="#handleMagicEnhance" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 16; -fx-background-radius: 6; -fx-cursor: hand;" text="✨ Magic Enhance" />

                        <Label fx:id="fileNameLabel" text="No file selected" style="-fx-text-fill: #94a3b8; -fx-font-style: italic;" />
                        <Button mnemonicParsing="false" onAction="#handleUploadFile" style="-fx-background-color: #f1f5f9; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-padding: 6 16; -fx-background-radius: 6; -fx-cursor: hand;" text="📎 Attach File" />
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

                <VBox VBox.vgrow="ALWAYS" spacing="5">
                    <TextArea fx:id="contentArea" promptText="What do you want to share? Write a quick draft and hit Magic Enhance!" wrapText="true" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-font-size: 14px; -fx-padding: 5;" VBox.vgrow="ALWAYS" />
                    <Label fx:id="contentError" text="Content must be at least 10 characters." style="-fx-text-fill: #ef4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false"/>
                </VBox>

                <Button fx:id="submitButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddPost" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-pref-height: 45; -fx-background-radius: 8; -fx-cursor: hand;" text="Post to Forum">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>