<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="550.0" prefWidth="450.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.forum.ForumActivityController">
    <VBox AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">

        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #1e293b; -fx-padding: 30;">
            <Circle fill="#3b82f6" radius="40.0" />
            <Label fx:id="usernameLabel" text="Loading..." style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label text="Forum Activity Summary" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold;" />
        </VBox>

        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20;">
            <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-pref-width: 110; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                <Label fx:id="postsCountLabel" text="-" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                <Label text="Posts" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>
            <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-pref-width: 110; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                <Label fx:id="upvotesCountLabel" text="-" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" />
                <Label text="Upvotes" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>
            <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-pref-width: 110; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                <Label fx:id="commentsCountLabel" text="-" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
                <Label text="Replies" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>
        </HBox>

        <VBox style="-fx-padding: 0 20 20 20;" VBox.vgrow="ALWAYS">
            <Label text="Recent Discussions" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 10 0;" />
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="recentPostsContainer" spacing="10.0" />
                </content>
            </ScrollPane>
        </VBox>
    </VBox>
</AnchorPane>