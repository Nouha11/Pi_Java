<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1050.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.forum.PostDetailsController">
    <children>

        <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: transparent; -fx-padding: 0 30;">
            <children>
                <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: white; -fx-cursor: hand; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 8 16; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);" text="← Back to Feed" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="25.0" style="-fx-padding: 10 30 40 30;">
                    <children>

                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-weight: bold;" text="Forum" />
                                    <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px;" text="›" />
                                    <Label fx:id="breadcrumbSpaceLabel" style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-weight: bold;" text="Space" />
                                    <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px;" text="›" />
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" text="Discussion Details" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="16.0">
                                    <Label fx:id="badgeSpaceLabel" style="-fx-background-color: #e0f2fe; -fx-text-fill: #0284c7; -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 6; -fx-font-size: 13px;" text="Space" />
                                    <Label fx:id="topTitleLabel" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #0f172a;" text="Post Title" />
                                </HBox>
                            </children>
                        </VBox>

                        <HBox spacing="25.0">
                            <children>

                                <VBox spacing="25.0" HBox.hgrow="ALWAYS">
                                    <children>

                                        <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                    <children>
                                                        <StackPane style="-fx-background-color: #3b82f6; -fx-background-radius: 50; -fx-min-width: 44; -fx-min-height: 44; -fx-max-width: 44; -fx-max-height: 44;">
                                                            <Label text="👤" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                                                        </StackPane>
                                                        <VBox spacing="2">
                                                            <Label fx:id="authorLabel" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 15px;" text="Username" />
                                                            <Label fx:id="dateLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" text="Posted on Date" />
                                                        </VBox>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="topCommentBadgeLabel" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 6; -fx-font-size: 13px;" text="0 Comments" />
                                                        <Label fx:id="upvoteBadgeLabel" style="-fx-background-color: #fffbeb; -fx-text-fill: #d97706; -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 6; -fx-font-size: 13px;" text="0 Upvotes" />
                                                    </children>
                                                </HBox>

                                                <Region prefHeight="1" style="-fx-background-color: #e2e8f0;" />

                                                <Label fx:id="contentLabel" style="-fx-font-size: 15px; -fx-text-fill: #334155; -fx-line-spacing: 6;" text="Post content goes here..." wrapText="true" />
                                                <ImageView fx:id="postImageView" fitWidth="600.0" preserveRatio="true" />

                                                <Region prefHeight="1" style="-fx-background-color: #e2e8f0;" />

                                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                    <Button fx:id="upvoteButton" onAction="#handleUpvote" style="-fx-background-color: #f1f5f9; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 16; -fx-background-radius: 8;" text="👍 Upvote" />
                                                    <Button style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 16;" text="🔖 Save" />
                                                    <Button style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 16;" text="↩ Reply" />

                                                    <Region HBox.hgrow="ALWAYS" />

                                                    <Button fx:id="lockButton" onAction="#handleLockPost" style="-fx-background-color: #fef3c7; -fx-text-fill: #d97706; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 16; -fx-background-radius: 6;" text="🔒 Lock" />
                                                    <Button fx:id="editButton" onAction="#handleEditPost" style="-fx-background-color: #e0f2fe; -fx-text-fill: #0284c7; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 16; -fx-background-radius: 6;" text="✏ Edit" />
                                                    <Button fx:id="deleteButton" onAction="#handleDeletePost" style="-fx-background-color: #ffe4e6; -fx-text-fill: #e11d48; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 16; -fx-background-radius: 6;" text="🗑 Delete" />
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                                            <children>
                                                <Label fx:id="repliesCountLabel" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #0f172a;" text="Replies (0)" />
                                                <Region prefHeight="1" style="-fx-background-color: #e2e8f0;" />

                                                <VBox spacing="10">
                                                    <TextArea fx:id="commentArea" prefHeight="90.0" promptText="Write a thoughtful reply..." style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-font-size: 14px; -fx-padding: 4;" wrapText="true" />
                                                    <HBox alignment="CENTER_RIGHT">
                                                        <Button fx:id="submitCommentBtn" onAction="#handleSubmitComment" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand;" text="Post Reply" />
                                                    </HBox>
                                                </VBox>

                                                <VBox fx:id="commentsContainer" spacing="15.0" style="-fx-padding: 10 0 0 0;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox spacing="25.0" prefWidth="300.0" minWidth="300.0">
                                    <children>

                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);" spacing="16.0">
                                            <Label style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #0f172a;" text="Discussion Stats" />
                                            <Region prefHeight="1" style="-fx-background-color: #e2e8f0;" />

                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <Label text="🛡" style="-fx-font-size: 16px;"/>
                                                <Label fx:id="statusLabel" style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 14px;" text="Status: Open" />
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <Label text="👁" style="-fx-font-size: 16px;"/>
                                                <Label fx:id="statsViewsLabel" style="-fx-text-fill: #475569; -fx-font-size: 14px;" text="Views: N/A" />
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <Label text="💬" style="-fx-font-size: 16px;"/>
                                                <Label fx:id="statsRepliesLabel" style="-fx-text-fill: #475569; -fx-font-size: 14px;" text="Replies: 0" />
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <Label text="👍" style="-fx-font-size: 16px;"/>
                                                <Label fx:id="statsUpvotesLabel" style="-fx-text-fill: #475569; -fx-font-size: 14px;" text="Upvotes: 0" />
                                            </HBox>
                                        </VBox>

                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);" spacing="16.0">
                                            <Label style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #0f172a;" text="Forum Rules" />
                                            <Region prefHeight="1" style="-fx-background-color: #e2e8f0;" />

                                            <HBox alignment="TOP_LEFT" spacing="10">
                                                <Label text="✔" style="-fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                                                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Be respectful to others and maintain a positive tone." wrapText="true"/>
                                            </HBox>
                                            <HBox alignment="TOP_LEFT" spacing="10">
                                                <Label text="✔" style="-fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                                                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="No spamming or self-promotion." wrapText="true"/>
                                            </HBox>
                                            <HBox alignment="TOP_LEFT" spacing="10">
                                                <Label text="✔" style="-fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                                                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Stay on topic within the specific space." wrapText="true"/>
                                            </HBox>
                                            <HBox alignment="TOP_LEFT" spacing="10">
                                                <Label text="✔" style="-fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                                                <Label style="-fx-text-fill: #475569; -fx-font-size: 13px;" text="Mark solutions when your question is answered." wrapText="true"/>
                                            </HBox>
                                        </VBox>

                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>