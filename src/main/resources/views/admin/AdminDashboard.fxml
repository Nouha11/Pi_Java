                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Г…В " styleClass="admin-nav-icon"/>
                            <Label text="Forum Statistics" styleClass="admin-nav-text"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <HBox styleClass="admin-user-card" alignment="CENTER_LEFT" spacing="10">
                <StackPane style="-fx-background-color: #1e293b; -fx-background-radius: 20;
                                  -fx-min-width: 34; -fx-min-height: 34; -fx-max-width: 34; -fx-max-height: 34;">
                    <Label text="A" style="-fx-text-fill: #a5b4fc; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblCurrentUser" text="Admin" styleClass="admin-user-name"/>
                    <Label fx:id="lblCurrentRole" text="ROLE_ADMIN" styleClass="admin-user-role"/>
                </VBox>
                <Label text="ГѓВўГ…ВЎГўвЂћВў" style="-fx-text-fill: #334155; -fx-font-size: 14px; -fx-cursor: hand;"/>
            </HBox>
            <Button text="Sign Out" onAction="#onLogout"
                    maxWidth="Infinity"
                    style="-fx-background-color:#ef4444;-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13px;-fx-padding:12 0;-fx-background-radius:0;-fx-cursor:hand;"/>
        </VBox>
    </left>

    <top>
        <HBox styleClass="admin-topbar" alignment="CENTER_LEFT" spacing="6">
            <Label text="NOVA" styleClass="admin-page-title"/>
            <Label text="ГѓВўГўвЂљВ¬Г‚Вє" styleClass="admin-breadcrumb-sep"/>
            <Label fx:id="lblPageTitle" text="Users" styleClass="admin-breadcrumb-sub"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #f1f5f9; -fx-background-radius: 20;
                         -fx-padding: 5 14; -fx-border-radius: 20;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1;">
                <Label text="ГѓВ°Г…ВёГўв‚¬ВќГўв‚¬в„ў" style="-fx-font-size: 11px;"/>
                <Label text="Admin Portal" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" styleClass="admin-content"/>
    </center>

</BorderPane>
