<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.admin.AdminDashboardController"
            stylesheets="@/css/admin.css"
            prefWidth="1300" prefHeight="820">

    <left>
        <VBox styleClass="admin-sidebar" spacing="0"
              BorderPane.alignment="TOP_LEFT">

            <HBox styleClass="admin-brand" alignment="CENTER_LEFT" spacing="12">
                <ImageView fitWidth="44" fitHeight="44" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@/images/nova-logo.png"/>
                    </image>
                </ImageView>
                <VBox spacing="2">
                    <Label text="NOVA" styleClass="admin-brand-name"/>
                    <Label text="Administration" styleClass="admin-brand-tag"/>
                </VBox>
            </HBox>

            <ScrollPane styleClass="admin-nav-scroll" fitToWidth="true"
                        VBox.vgrow="ALWAYS" maxHeight="Infinity">
                <VBox spacing="0" style="-fx-padding: 4 0 12 0;">

                    <VBox style="-fx-padding: 8 8 4 8;">
                        <HBox fx:id="navHome" styleClass="admin-nav-row-active"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showHome">
                            <Label text="ГѓВўГ‚В¬Г‚ВЎ" style="-fx-font-size:14px; -fx-text-fill:#818cf8;"/>
                            <Label text="Overview" styleClass="admin-nav-text-active"/>
                        </HBox>
                    </VBox>

                    <Button fx:id="btnToggleUsers" styleClass="admin-group-btn"
                            text="USERS  ГѓВўГўв‚¬вЂњГ‚Вѕ" onAction="#toggleUsers" maxWidth="Infinity"/>
                    <VBox fx:id="usersGroup" spacing="1" style="-fx-padding: 0 8 4 8;">
                        <HBox fx:id="navUsers" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showUsers">
                            <Label text="ГѓВ°Г…ВёГўв‚¬ЛњГ‚В¤" styleClass="admin-nav-icon"/>
                            <Label text="All Users" styleClass="admin-nav-text"/>
                        </HBox>
                    </VBox>

                    <Button fx:id="btnToggleLibrary" styleClass="admin-group-btn"
                            text="LIBRARY  ГѓВўГўв‚¬вЂњГ‚Вѕ" onAction="#toggleLibrary" maxWidth="Infinity"/>
                    <VBox fx:id="libraryGroup" spacing="1" style="-fx-padding: 0 8 4 8;">
                        <HBox fx:id="navBooks" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showBooks">
                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Г…ВЎ" styleClass="admin-nav-icon"/>
                            <Label text="Books" styleClass="admin-nav-text"/>
                        </HBox>
                        <HBox fx:id="navLoans" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showLoans">
                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Гўв‚¬В№" styleClass="admin-nav-icon"/>
                            <Label text="Loans" styleClass="admin-nav-text"/>
                        </HBox>
                        <HBox fx:id="navPayments" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showPayments">
                            <Label text="ГѓВ°Г…ВёГўв‚¬в„ўГ‚Ві" styleClass="admin-nav-icon"/>
                            <Label text="Payments" styleClass="admin-nav-text"/>
                        </HBox>
                    </VBox>

                    <Button fx:id="btnToggleStudy" styleClass="admin-group-btn"
                            text="STUDY SESSION  ГѓВўГўв‚¬вЂњГ‚Вѕ" onAction="#toggleStudy" maxWidth="Infinity"/>
                    <VBox fx:id="studyGroup" spacing="1" style="-fx-padding: 0 8 4 8;">
                        <HBox fx:id="navCourses" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showCourses">
                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Г‹Е“" styleClass="admin-nav-icon"/>
                            <Label text="Courses" styleClass="admin-nav-text"/>
                        </HBox>
                        <HBox fx:id="navPlannings" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showPlannings">
                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Гўв‚¬В¦" styleClass="admin-nav-icon"/>
                            <Label text="Plannings" styleClass="admin-nav-text"/>
                        </HBox>
                        <HBox fx:id="navSessions" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showSessions">
                            <Label text="ГѓВўГ‚ВЏГ‚В±" styleClass="admin-nav-icon"/>
                            <Label text="Study Sessions" styleClass="admin-nav-text"/>
                        </HBox>
                        <HBox fx:id="navStudyStats" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showStudyStats">
                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Г…В " styleClass="admin-nav-icon"/>
                            <Label text="Statistics" styleClass="admin-nav-text"/>
                        </HBox>
                    </VBox>

                    <Button fx:id="btnToggleGame" styleClass="admin-group-btn"
                            text="GAMIFICATION  ГѓВўГўв‚¬вЂњГ‚Вѕ" onAction="#toggleGame" maxWidth="Infinity"/>
                    <VBox fx:id="gameGroup" spacing="1" style="-fx-padding: 0 8 4 8;">
                        <HBox fx:id="navGames" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showGames">
                            <Label text="ГѓВ°Г…ВёГ…ВЅГ‚В®" styleClass="admin-nav-icon"/>
                            <Label text="Games" styleClass="admin-nav-text"/>
                        </HBox>
                        <HBox fx:id="navRewards" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showRewards">
                            <Label text="ГѓВ°Г…ВёГ‚ВЏГўв‚¬В " styleClass="admin-nav-icon"/>
                            <Label text="Rewards" styleClass="admin-nav-text"/>
                        </HBox>
                        <HBox fx:id="navGameStats" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showGameStats">
                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Г‹вЂ " styleClass="admin-nav-icon"/>
                            <Label text="Statistics" styleClass="admin-nav-text"/>
                        </HBox>
                    </VBox>

                    <Button fx:id="btnToggleQuiz" styleClass="admin-group-btn"
                            text="QUIZ  ГѓВўГўв‚¬вЂњГ‚Вѕ" onAction="#toggleQuiz" maxWidth="Infinity"/>
                    <VBox fx:id="quizGroup" spacing="1" style="-fx-padding: 0 8 4 8;">
                        <HBox fx:id="navQuizzes" styleClass="admin-nav-row"
                              alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showQuizzes">
                            <Label text="ГѓВ°Г…ВёГўв‚¬Е“Г‚Вќ" styleClass="admin-nav-icon"/>
                            <Label text="Quizzes" styleClass="admin-nav-text"/>
                        </HBox>
                    </VBox>

                    <Button fx:id="btnToggleForum" styleClass="admin-group-btn"
