<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f8fafc; -fx-background: #f8fafc; -fx-border-color: transparent;" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.admin.AdminHomeController">

    <VBox fx:id="rootVBox" spacing="25" style="-fx-padding: 30;">

        <StackPane fx:id="heroStack" style="-fx-background-color: linear-gradient(to right bottom, #1e293b, #334155); -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 15, 0, 0, 5);">
            <VBox fx:id="headerPane" spacing="0" style="-fx-padding: 35 40;">
                <HBox alignment="CENTER_LEFT" spacing="25">
                    <ImageView fx:id="heroLogo" fitWidth="80" fitHeight="80" preserveRatio="true" smooth="true">
                        <image><Image url="@/images/nova-logo.png"/></image>
                    </ImageView>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblGreeting" text="Good morning, Admin" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                        <Label text="Here is what is happening across your platform today." style="-fx-text-fill: #94a3b8; -fx-font-size: 15px;"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="8">
                        <Label fx:id="lblDate" text="—" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-padding: 8 16; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Label fx:id="lblTime" text="—" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>
            <Pane fx:id="particlePane" mouseTransparent="true" style="-fx-background-color: transparent;"/>
        </StackPane>

        <HBox fx:id="statsRow1" spacing="20">
            <VBox fx:id="cardUsers" HBox.hgrow="ALWAYS" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #eff6ff; -fx-background-radius: 8; -fx-padding: 10;"><Label text="👥" style="-fx-font-size: 18px;"/></StackPane>
                    <Label text="Total Users" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Label fx:id="statUsers" text="—" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="statUsersDetail" text="— active" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </VBox>

            <VBox fx:id="cardBooks" HBox.hgrow="ALWAYS" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #f5f3ff; -fx-background-radius: 8; -fx-padding: 10;"><Label text="📚" style="-fx-font-size: 18px;"/></StackPane>
                    <Label text="Books" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Label fx:id="statBooks" text="—" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="statBooksDetail" text="— digital · — physical" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            </VBox>

            <VBox fx:id="cardLoans" HBox.hgrow="ALWAYS" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #fffbeb; -fx-background-radius: 8; -fx-padding: 10;"><Label text="📋" style="-fx-font-size: 18px;"/></StackPane>
                    <Label text="Loans" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Label fx:id="statLoans" text="—" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="statLoansDetail" text="— pending" style="-fx-text-fill: #f59e0b; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </VBox>

            <VBox fx:id="cardGames" HBox.hgrow="ALWAYS" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #ecfdf5; -fx-background-radius: 8; -fx-padding: 10;"><Label text="🎮" style="-fx-font-size: 18px;"/></StackPane>
                    <Label text="Games" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Label fx:id="statGames" text="—" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="statGamesDetail" text="— active" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </VBox>
        </HBox>

        <HBox fx:id="statsRow2" spacing="20">
            <VBox fx:id="cardRewards" HBox.hgrow="ALWAYS" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #fff1f2; -fx-background-radius: 8; -fx-padding: 10;"><Label text="🏆" style="-fx-font-size: 18px;"/></StackPane>
                    <Label text="Rewards" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Label fx:id="statRewards" text="—" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="statRewardsDetail" text="— active" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </VBox>

            <VBox fx:id="cardQuizzes" HBox.hgrow="ALWAYS" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #eff6ff; -fx-background-radius: 8; -fx-padding: 10;"><Label text="📝" style="-fx-font-size: 18px;"/></StackPane>
                    <Label text="Quizzes" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Label fx:id="statQuizzes" text="—" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="statQuizzesDetail" text="— questions total" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
            </VBox>

            <VBox fx:id="cardForum" HBox.hgrow="ALWAYS" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #eef2ff; -fx-background-radius: 8; -fx-padding: 10;"><Label text="💬" style="-fx-font-size: 18px;"/></StackPane>
                    <Label text="Forum Posts" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Label fx:id="statForum" text="—" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="statForumDetail" text="— active discussions" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <HBox fx:id="contentArea" spacing="25" alignment="TOP_LEFT">

            <VBox fx:id="coursesPanel" HBox.hgrow="ALWAYS" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Recent Courses" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                        <Label text="Latest courses added to the platform" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;" onMouseClicked="#onViewAllCourses"/>
                </HBox>

                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 12 24; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <Label text="COURSE NAME" prefWidth="250" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="CATEGORY" prefWidth="120" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="DIFFICULTY" prefWidth="100" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="STATUS" prefWidth="100" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>

                <ScrollPane fitToWidth="true" prefHeight="260" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="coursesListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="sidebar" spacing="25" prefWidth="320">
                <VBox fx:id="quickActionsCard" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                        <Label text="Quick Actions" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox spacing="10" style="-fx-padding: 20 24;">
                        <Button text="➕ Add New Book" maxWidth="Infinity" alignment="CENTER_LEFT" onAction="#quickAddBook" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="👥 Manage Users" maxWidth="Infinity" alignment="CENTER_LEFT" onAction="#quickUsers" style="-fx-background-color: #f8fafc; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📊 View Game Stats" maxWidth="Infinity" alignment="CENTER_LEFT" onAction="#quickGameStats" style="-fx-background-color: #f8fafc; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-cursor: hand;"/>
                        <Button text="💬 Manage Forum" maxWidth="Infinity" alignment="CENTER_LEFT" onAction="#quickForum" style="-fx-background-color: #f8fafc; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 16; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>

                <VBox fx:id="rolesCard" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                        <Label text="Users by Role" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox spacing="15" style="-fx-padding: 20 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: #3b82f6; -fx-background-radius: 50; -fx-min-width: 12; -fx-min-height: 12; -fx-max-width: 12; -fx-max-height: 12;"/>
                            <Label text="Students" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="roleStudents" text="—" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 16px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: #8b5cf6; -fx-background-radius: 50; -fx-min-width: 12; -fx-min-height: 12; -fx-max-width: 12; -fx-max-height: 12;"/>
                            <Label text="Tutors" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="roleTutors" text="—" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 16px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: #f59e0b; -fx-background-radius: 50; -fx-min-width: 12; -fx-min-height: 12; -fx-max-width: 12; -fx-max-height: 12;"/>
                            <Label text="Admins" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="roleAdmins" text="—" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 16px;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>

        <HBox fx:id="row2" spacing="25" alignment="TOP_LEFT">
            <VBox fx:id="loansPanel" HBox.hgrow="ALWAYS" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Recent Loan Requests" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                        <Label text="Pending and active book loans" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;" onMouseClicked="#onViewAllLoans"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 12 24; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <Label text="BOOK TITLE" prefWidth="220" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="USER" prefWidth="130" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="STATUS" prefWidth="120" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="DATE REQUESTED" prefWidth="110" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="260" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="loansListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="gamesPanel" prefWidth="380" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Top Games" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                        <Label text="Most rewarding active games" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;" onMouseClicked="#onViewAllGames"/>
                </HBox>
                <VBox fx:id="topGamesBox" spacing="0" style="-fx-padding: 8 0 16 0;"/>
            </VBox>
        </HBox>

        <HBox fx:id="row3" spacing="25" alignment="TOP_LEFT">
            <VBox fx:id="quizzesPanel" HBox.hgrow="ALWAYS" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Recent Quizzes" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                        <Label text="Latest quizzes on the platform" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;" onMouseClicked="#onViewAllQuizzes"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 12 24; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <Label text="QUIZ TITLE" prefWidth="350" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="QUESTIONS" prefWidth="100" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="240" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="quizzesListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="rewardsPanel" prefWidth="380" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Top Rewards" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                        <Label text="Highest value active rewards" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;" onMouseClicked="#onViewAllRewards"/>
                </HBox>
                <VBox fx:id="topRewardsBox" spacing="0" style="-fx-padding: 8 0 16 0;"/>
            </VBox>
        </HBox>

        <HBox fx:id="row4" spacing="25" alignment="TOP_LEFT">
            <VBox fx:id="recentGamesPanel" HBox.hgrow="ALWAYS" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Recent Games" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                        <Label text="Latest games added to the platform" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;" onMouseClicked="#onViewAllGames"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 12 24; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <Label text="GAME NAME" prefWidth="180" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="TYPE" prefWidth="100" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="DIFFICULTY" prefWidth="100" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="XP REWARD" prefWidth="90" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="260" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="gamesListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="recentRewardsPanel" HBox.hgrow="ALWAYS" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Recent Rewards" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;"/>
                        <Label text="Latest rewards added to the platform" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-cursor: hand;" onMouseClicked="#onViewAllRewards"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 12 24; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                    <Label text="REWARD NAME" prefWidth="200" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="TYPE" prefWidth="140" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="VALUE" prefWidth="80" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="260" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="rewardsListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>
        </HBox>

        <Region prefHeight="40"/>
    </VBox>
</ScrollPane>