<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.admin.AdminHomeController"
            styleClass="root-scroll"
            stylesheets="@/css/admin-home.css">

    <VBox fx:id="rootVBox" spacing="0" styleClass="root-container">

        <StackPane fx:id="heroStack">
            <VBox fx:id="headerPane" styleClass="hero-header" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="32" styleClass="hero-inner">
                    <ImageView fx:id="heroLogo" fitWidth="120" fitHeight="120" preserveRatio="true" smooth="true">
                        <image><Image url="@/images/nova-logo.png"/></image>
                    </ImageView>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblGreeting" text="Good morning, Admin" styleClass="hero-title"/>
                        <Label text="Here's what's happening across your platform today." styleClass="hero-subtitle"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="6">
                        <Label fx:id="lblDate" text="—" styleClass="date-badge"/>
                        <Label fx:id="lblTime" text="—" styleClass="time-badge"/>
                    </VBox>
                </HBox>
            </VBox>
            <Pane fx:id="particlePane" mouseTransparent="true" style="-fx-background-color: transparent;"/>
        </StackPane>

        <HBox fx:id="statsRow1" spacing="16" styleClass="stats-row">
            <VBox fx:id="cardUsers" styleClass="stat-card card-blue" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="stat-icon-bg"><Label text="👥" styleClass="stat-icon"/></StackPane>
                    <Label text="Total Users" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="statUsers" text="—" styleClass="stat-number"/>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="↑" styleClass="trend-arrow-up"/>
                    <Label fx:id="statUsersDetail" text="— active" styleClass="stat-detail-positive"/>
                </HBox>
            </VBox>
            <VBox fx:id="cardBooks" styleClass="stat-card card-violet" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="stat-icon-bg"><Label text="📚" styleClass="stat-icon"/></StackPane>
                    <Label text="Books" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="statBooks" text="—" styleClass="stat-number"/>
                <Label fx:id="statBooksDetail" text="— digital · — physical" styleClass="stat-detail-neutral"/>
            </VBox>
            <VBox fx:id="cardLoans" styleClass="stat-card card-amber" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="stat-icon-bg"><Label text="📋" styleClass="stat-icon"/></StackPane>
                    <Label text="Loans" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="statLoans" text="—" styleClass="stat-number"/>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="⏳" styleClass="stat-icon-tiny"/>
                    <Label fx:id="statLoansDetail" text="— pending" styleClass="stat-detail-warning"/>
                </HBox>
            </VBox>
            <VBox fx:id="cardGames" styleClass="stat-card card-emerald" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="stat-icon-bg"><Label text="🎮" styleClass="stat-icon"/></StackPane>
                    <Label text="Games" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="statGames" text="—" styleClass="stat-number"/>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="↑" styleClass="trend-arrow-up"/>
                    <Label fx:id="statGamesDetail" text="— active" styleClass="stat-detail-positive"/>
                </HBox>
            </VBox>
        </HBox>

        <HBox fx:id="statsRow2" spacing="16" styleClass="stats-row" style="-fx-padding: 0 36 0 36;">
            <VBox fx:id="cardRewards" styleClass="stat-card card-rose" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="stat-icon-bg"><Label text="🏆" styleClass="stat-icon"/></StackPane>
                    <Label text="Rewards" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="statRewards" text="—" styleClass="stat-number"/>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="↑" styleClass="trend-arrow-up"/>
                    <Label fx:id="statRewardsDetail" text="— active" styleClass="stat-detail-positive"/>
                </HBox>
            </VBox>
            <VBox fx:id="cardQuizzes" styleClass="stat-card card-blue" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="stat-icon-bg"><Label text="📝" styleClass="stat-icon"/></StackPane>
                    <Label text="Quizzes" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="statQuizzes" text="—" styleClass="stat-number"/>
                <Label fx:id="statQuizzesDetail" text="— questions total" styleClass="stat-detail-neutral"/>
            </VBox>
            <VBox fx:id="cardForum" styleClass="stat-card card-indigo" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="stat-icon-bg"><Label text="💬" styleClass="stat-icon"/></StackPane>
                    <Label text="Forum Posts" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="statForum" text="—" styleClass="stat-number"/>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="●" styleClass="live-dot"/>
                    <Label fx:id="statForumDetail" text="— open discussions" styleClass="stat-detail-positive"/>
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="contentArea" spacing="20" styleClass="content-area" alignment="TOP_LEFT">

            <VBox fx:id="coursesPanel" styleClass="content-card" HBox.hgrow="ALWAYS" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="card-header" style="-fx-padding: 15;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Recent Courses" styleClass="card-title" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Latest courses added to the platform" styleClass="card-subtitle" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-cursor: hand;" onMouseClicked="#onViewAllCourses"/>
                </HBox>

                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 10 16; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 1 0;">
                    <Label text="COURSE NAME" prefWidth="250" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="CATEGORY" prefWidth="120" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="DIFFICULTY" prefWidth="100" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="STATUS" prefWidth="100" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>

                <ScrollPane fitToWidth="true" prefHeight="220" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="coursesListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="sidebar" spacing="16" prefWidth="290">
                <VBox fx:id="quickActionsCard" styleClass="content-card" spacing="0">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT">
                        <Label text="Quick Actions" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox spacing="8" style="-fx-padding: 14 16 16 16;">
                        <Button text="Add New Book"    maxWidth="Infinity" onAction="#quickAddBook"    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 6;"/>
                        <Button text="Manage Users"    maxWidth="Infinity" onAction="#quickUsers"      style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 6;"/>
                        <Button text="View Game Stats" maxWidth="Infinity" onAction="#quickGameStats"  style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 6;"/>
                        <Button text="Manage Forum"    maxWidth="Infinity" onAction="#quickForum"      style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 6;"/>
                    </VBox>
                </VBox>

                <VBox fx:id="rolesCard" styleClass="content-card" spacing="0">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT">
                        <Label text="Users by Role" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox spacing="0" style="-fx-padding: 8 16 12 16;">
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="role-row">
                            <StackPane styleClass="role-dot-blue"/>
                            <Label text="Students" styleClass="role-name" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="roleStudents" text="—" styleClass="role-count"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="role-row">
                            <StackPane styleClass="role-dot-violet"/>
                            <Label text="Tutors" styleClass="role-name" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="roleTutors" text="—" styleClass="role-count"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="role-row">
                            <StackPane styleClass="role-dot-amber"/>
                            <Label text="Admins" styleClass="role-name" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="roleAdmins" text="—" styleClass="role-count"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>

        <HBox fx:id="row2" spacing="20" styleClass="content-area" alignment="TOP_LEFT">
            <VBox fx:id="loansPanel" styleClass="content-card" HBox.hgrow="ALWAYS" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="card-header" style="-fx-padding: 15;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Recent Loan Requests" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Pending and active book loans" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-cursor: hand;" onMouseClicked="#onViewAllLoans"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 10 16; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 1 0;">
                    <Label text="BOOK TITLE" prefWidth="220" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="USER" prefWidth="130" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="STATUS" prefWidth="120" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="DATE REQUESTED" prefWidth="110" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="220" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="loansListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="gamesPanel" styleClass="content-card" prefWidth="340" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="card-header">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Top Games" styleClass="card-title"/>
                        <Label text="Most rewarding active games" styleClass="card-subtitle"/>
                    </VBox>
                    <Label text="View all →" styleClass="card-link" onMouseClicked="#onViewAllGames"/>
                </HBox>
                <VBox fx:id="topGamesBox" spacing="0" style="-fx-padding: 4 0 8 0;"/>
            </VBox>
        </HBox>

        <HBox fx:id="row3" spacing="20" styleClass="content-area" alignment="TOP_LEFT">
            <VBox fx:id="quizzesPanel" styleClass="content-card" HBox.hgrow="ALWAYS" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="card-header" style="-fx-padding: 15;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Recent Quizzes" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Latest quizzes on the platform" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-cursor: hand;" onMouseClicked="#onViewAllQuizzes"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 10 16; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 1 0;">
                    <Label text="QUIZ TITLE" prefWidth="350" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="QUESTIONS" prefWidth="100" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="200" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="quizzesListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="rewardsPanel" styleClass="content-card" prefWidth="340" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="card-header">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Top Rewards" styleClass="card-title"/>
                        <Label text="Highest value active rewards" styleClass="card-subtitle"/>
                    </VBox>
                    <Label text="View all →" styleClass="card-link" onMouseClicked="#onViewAllRewards"/>
                </HBox>
                <VBox fx:id="topRewardsBox" spacing="0" style="-fx-padding: 4 0 8 0;"/>
            </VBox>
        </HBox>

        <HBox fx:id="row4" spacing="20" styleClass="content-area" alignment="TOP_LEFT">
            <VBox fx:id="recentGamesPanel" styleClass="content-card" HBox.hgrow="ALWAYS" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="card-header" style="-fx-padding: 15;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Recent Games" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Latest games added to the platform" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-cursor: hand;" onMouseClicked="#onViewAllGames"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 10 16; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 1 0;">
                    <Label text="GAME NAME" prefWidth="180" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="TYPE" prefWidth="100" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="DIFFICULTY" prefWidth="100" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="XP REWARD" prefWidth="90" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="220" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="gamesListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="recentRewardsPanel" styleClass="content-card" HBox.hgrow="ALWAYS" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="card-header" style="-fx-padding: 15;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Recent Rewards" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Latest rewards added to the platform" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                    <Label text="View all →" style="-fx-text-fill: #3b82f6; -fx-cursor: hand;" onMouseClicked="#onViewAllRewards"/>
                </HBox>
                <HBox style="-fx-background-color: #f8fafc; -fx-padding: 10 16; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 1 0;">
                    <Label text="REWARD NAME" prefWidth="200" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="TYPE" prefWidth="140" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    <Label text="VALUE" prefWidth="80" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="220" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="rewardsListContainer" spacing="0"/>
                </ScrollPane>
            </VBox>
        </HBox>

        <Region prefHeight="32"/>
    </VBox>
</ScrollPane>