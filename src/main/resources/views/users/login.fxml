<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.shape.SVGPath?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.users.LoginController"
      styleClass="login-root" prefWidth="1100" prefHeight="720"
      maxWidth="Infinity" maxHeight="Infinity">

    <stylesheets>
        <String fx:value="/css/login.css"/>
    </stylesheets>

    <StackPane fx:id="leftPanel" prefWidth="500" alignment="CENTER" style="-fx-background-color: #1a1a2e;">

        <Pane fx:id="animatedSceneContainer" prefWidth="500" prefHeight="580" styleClass="animated-scene-bg"/>

        <VBox alignment="CENTER">
            <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

            <VBox spacing="16" alignment="CENTER_LEFT" maxWidth="340" maxHeight="320"
                  style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 16; -fx-padding: 30; -fx-border-color: rgba(255, 255, 255, 0.08); -fx-border-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 5);">

                <VBox spacing="4">
                    <Label text="Study Smarter." style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Level Up Together." style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;"/>
                </VBox>

                <Region prefHeight="8"/>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <SVGPath content="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 6 18.5 6s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" fill="#0d6efd" scaleX="0.9" scaleY="0.9"/>
                    <Label text="Play and learn with study games" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px;"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="#0d6efd" scaleX="0.9" scaleY="0.9"/>
                    <Label text="Tutor peers and join discussions" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px;"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <SVGPath content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="#0d6efd" scaleX="0.9" scaleY="0.9"/>
                    <Label text="Take quizzes and earn rewards" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px;"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <SVGPath content="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z" fill="#0d6efd" scaleX="0.9" scaleY="0.9"/>
                    <Label text="Unlock courses &amp; library access" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px;"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>

    <VBox fx:id="rightPanel" styleClass="form-panel" alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS">
        <padding><Insets top="0" right="70" bottom="0" left="70"/></padding>

        <VBox alignment="CENTER_LEFT" spacing="0" maxWidth="340">

            <ImageView fitHeight="70" preserveRatio="true">
                <image>
                    <Image url="@/images/nova-logo.png"/>
                </image>
            </ImageView>

            <Region prefHeight="15"/>

            <VBox spacing="4">
                <Label text="Welcome back" styleClass="form-title" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Sign in to your account to continue" styleClass="form-hint" style="-fx-text-fill: #64748b; -fx-font-size: 15px;"/>
            </VBox>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="No account?" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    <Label text="Sign Up" style="-fx-text-fill: #0d6efd; -fx-font-size: 13px; -fx-cursor: hand; -fx-font-weight: bold;" onMouseClicked="#onGoToSignup"/>
                </HBox>

            <Region prefHeight="35"/>

            <VBox spacing="8">
                <Label text="USERNAME" styleClass="field-label" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="tfUsername"
                           promptText="Enter your username"
                           styleClass="form-field"
                           style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-background-color: #f8fafc;"/>
            </VBox>

            <Region prefHeight="15"/>

            <VBox spacing="8">
                <Label text="PASSWORD" styleClass="field-label" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <PasswordField fx:id="pfPassword"
                               promptText="Enter your password"
                               styleClass="form-field"
                               style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-background-color: #f8fafc;"/>
            </VBox>

            <Region prefHeight="8"/>

            <Label fx:id="lblError" text="" wrapText="true"
                   styleClass="form-error" maxWidth="340" style="-fx-text-fill: #ef4444;"/>

            <ProgressIndicator fx:id="spinner" prefWidth="28" prefHeight="28"
                               styleClass="form-spinner" visible="false" managed="false"/>

            <Region prefHeight="15"/>

            <!-- reCAPTCHA-style checkbox -->
            <HBox fx:id="captchaBox" alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: #f8fafc; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-border-width: 1.5; -fx-padding: 14 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 2);"
                  onMouseMoved="#onCaptchaMouseMoved">

                <!-- Checkbox area -->
                <StackPane fx:id="captchaCheckPane" prefWidth="28" prefHeight="28"
                           style="-fx-background-color: white; -fx-border-color: #9ca3af; -fx-border-radius: 3; -fx-border-width: 2; -fx-cursor: hand; -fx-background-radius: 3;"
                           onMouseClicked="#onCaptchaClick">
                    <Label fx:id="lblCaptchaCheck" text="" style="-fx-font-size: 18px; -fx-text-fill: #1a73e8;"/>
                </StackPane>

                <!-- Label -->
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="I am not a robot" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #374151;"/>
                    <Label fx:id="lblCaptchaStatus" text="" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                </VBox>

                <!-- reCAPTCHA branding -->
                <VBox alignment="CENTER" spacing="2" style="-fx-padding: 0 4;">
                    <Label text="reCAPTCHA" style="-fx-font-size: 9px; -fx-text-fill: #9ca3af; -fx-font-weight: bold;"/>
                    <Label text="Privacy - Terms" style="-fx-font-size: 8px; -fx-text-fill: #9ca3af;"/>
                </VBox>
            </HBox>

            <Region prefHeight="10"/>

            <Button fx:id="btnLogin" text="SIGN IN"
                    onAction="#onLogin"
                    styleClass="form-btn"
                    maxWidth="Infinity"
                    style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </VBox>
</HBox>
