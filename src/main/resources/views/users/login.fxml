<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.users.LoginController" prefWidth="900" prefHeight="580">
    <stylesheets><String fx:value="/css/login.css"/></stylesheets>
    <HBox maxWidth="Infinity" maxHeight="Infinity">
        <StackPane fx:id="leftPanel" styleClass="brand-panel" prefWidth="420">
            <Pane fx:id="animatedSceneContainer"/>
            <VBox alignment="CENTER" spacing="18">
                <padding><Insets top="60" right="50" bottom="60" left="50"/></padding>
                <Label text="NOVA" style="-fx-font-size:48px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="Intelligent Study Coaching Platform" styleClass="brand-subtitle" wrapText="true" textAlignment="CENTER"/>
                <Region prefHeight="30"/>
                <VBox spacing="12" alignment="CENTER_LEFT">
                    <HBox spacing="10" alignment="CENTER_LEFT"><Label text="+" styleClass="bullet"/><Label text="Full user lifecycle management" styleClass="brand-feature"/></HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT"><Label text="+" styleClass="bullet"/><Label text="Role-based access control" styleClass="brand-feature"/></HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT"><Label text="+" styleClass="bullet"/><Label text="Real-time statistics and analytics" styleClass="brand-feature"/></HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT"><Label text="+" styleClass="bullet"/><Label text="Search, filter and export" styleClass="brand-feature"/></HBox>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <Label text="2026 NOVA Platform" styleClass="brand-footer"/>
            </VBox>
        </StackPane>
        <VBox fx:id="rightPanel" styleClass="form-panel" alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS">
            <padding><Insets top="0" right="60" bottom="0" left="60"/></padding>
            <HBox styleClass="form-topbar" alignment="CENTER_RIGHT">
                <padding><Insets top="16" bottom="16"/></padding>
                <Label text="Admin Portal" styleClass="form-topbar-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="No account? " styleClass="form-topbar-label"/>
                <Label text="Sign Up" styleClass="form-topbar-label" style="-fx-text-fill:#4f8ef7;-fx-cursor:hand;-fx-font-weight:bold;" onMouseClicked="#onGoToSignup"/>
            </HBox>
            <Region prefHeight="20"/>
            <VBox spacing="6">
                <Label text="Welcome back" styleClass="form-title"/>
                <Label text="Sign in to your account to continue" styleClass="form-hint"/>
            </VBox>
            <Region prefHeight="32"/>
            <VBox spacing="7">
                <Label text="USERNAME" styleClass="field-label"/>
                <TextField fx:id="tfUsername" promptText="Enter your username" styleClass="form-field"/>
            </VBox>
            <Region prefHeight="18"/>
            <VBox spacing="7">
                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="pfPassword" promptText="Enter your password" styleClass="form-field"/>
            </VBox>
            <Region prefHeight="10"/>
            <Label fx:id="lblError" text="" wrapText="true" styleClass="form-error" maxWidth="340"/>
            <ProgressIndicator fx:id="spinner" prefWidth="28" prefHeight="28" styleClass="form-spinner" visible="false" managed="false"/>
            <Region prefHeight="18"/>
            <Button fx:id="btnLogin" text="SIGN IN" onAction="#onLogin" styleClass="form-btn" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER"><padding><Insets bottom="24"/></padding><Label text="NOVA User Management  v1.0" styleClass="form-version"/></HBox>
        </VBox>
    </HBox>
</StackPane>