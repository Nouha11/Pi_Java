<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  Desktop main window — BorderPane layout:
  LEFT   = dark sidebar
  TOP    = top bar (title + user info)
  CENTER = content (stats cards + toolbar + table)
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.users.UserListController"
            styleClass="app-root" prefWidth="1200" prefHeight="740">

    <!-- ══════════════════════════════════════════════
         LEFT — Sidebar
         ══════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="0" right="0" bottom="16" left="0"/></padding>

            <!-- App logo -->
            <VBox styleClass="sidebar-logo" alignment="CENTER" spacing="4">
                <padding><Insets top="24" bottom="24"/></padding>
                <Label text="🎓" style="-fx-font-size:36px;"/>
                <Label text="NOVA" styleClass="sidebar-app-name"/>
                <Label text="Admin Panel" styleClass="sidebar-app-sub"/>
            </VBox>

            <Separator styleClass="sidebar-sep"/>
            <Region prefHeight="8"/>

            <!-- Nav label -->
            <Label text="USER MANAGEMENT" styleClass="sidebar-section-label">
                <padding><Insets left="20" bottom="4"/></padding>
            </Label>

            <!-- Nav items (active = Users) -->
            <HBox styleClass="nav-item nav-item-active" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="11" right="16" bottom="11" left="20"/></padding>
                <Label text="👥" style="-fx-font-size:16px;"/>
                <Label text="All Users" styleClass="nav-label-active"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-sep"/>

            <!-- Logged-in user info -->
            <HBox fx:id="hboxCurrentUser" styleClass="sidebar-user" alignment="CENTER_LEFT" spacing="10">
                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                <Label text="👤" style="-fx-font-size:22px;"/>
                <VBox spacing="2">
                    <Label fx:id="lblCurrentUser" text="Admin" styleClass="sidebar-username"/>
                    <Label fx:id="lblCurrentRole" text="ROLE_ADMIN" styleClass="sidebar-role"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════
         TOP — Top bar
         ══════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>

            <Label text="User Management" styleClass="topbar-title"/>
            <Label text="/" styleClass="topbar-sep"/>
            <Label text="All Users" styleClass="topbar-sub"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Search -->
            <TextField fx:id="tfSearch"
                       promptText="  🔍  Search username or email…"
                       prefWidth="280" onAction="#onSearch"
                       styleClass="topbar-search"/>
            <Button text="Search" onAction="#onSearch" styleClass="btn-primary"/>

            <!-- Role filter -->
            <ComboBox fx:id="cbRoleFilter" onAction="#onFilter"
                      prefWidth="140" styleClass="topbar-combo"/>

            <!-- Buttons -->
            <Button text="＋  Add User" onAction="#onAddUser" styleClass="btn-success"/>
            <Button text="↺" onAction="#onRefresh" styleClass="btn-icon">
                <tooltip><Tooltip text="Refresh"/></tooltip>
            </Button>
        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════
         CENTER — Content
         ══════════════════════════════════════════════ -->
    <center>
        <VBox styleClass="content-area" spacing="16">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- ── Stats cards row ── -->
            <HBox spacing="14">
                <!-- Total -->
                <VBox styleClass="stat-card stat-card-blue" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <Label text="TOTAL USERS" styleClass="stat-label"/>
                    <Label fx:id="lblTotal" text="0" styleClass="stat-value"/>
                </VBox>
                <!-- Active -->
                <VBox styleClass="stat-card stat-card-green" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <Label text="ACTIVE" styleClass="stat-label"/>
                    <Label fx:id="lblActive" text="0" styleClass="stat-value"/>
                </VBox>
                <!-- Banned -->
                <VBox styleClass="stat-card stat-card-red" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <Label text="BANNED" styleClass="stat-label"/>
                    <Label fx:id="lblBanned" text="0" styleClass="stat-value"/>
                </VBox>
                <!-- Verified -->
                <VBox styleClass="stat-card stat-card-purple" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <Label text="VERIFIED" styleClass="stat-label"/>
                    <Label fx:id="lblVerified" text="0" styleClass="stat-value"/>
                </VBox>
                <!-- Students -->
                <VBox styleClass="stat-card stat-card-orange" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <Label text="STUDENTS" styleClass="stat-label"/>
                    <Label fx:id="lblStudents" text="0" styleClass="stat-value"/>
                </VBox>
                <!-- Tutors -->
                <VBox styleClass="stat-card stat-card-teal" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <Label text="TUTORS" styleClass="stat-label"/>
                    <Label fx:id="lblTutors" text="0" styleClass="stat-value"/>
                </VBox>
                <!-- Admins -->
                <VBox styleClass="stat-card stat-card-dark" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <Label text="ADMINS" styleClass="stat-label"/>
                    <Label fx:id="lblAdmins" text="0" styleClass="stat-value"/>
                </VBox>
            </HBox>

            <!-- ── Table ── -->
            <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS" styleClass="main-table">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"       prefWidth="55"/>
                    <TableColumn fx:id="colUsername" text="Username" prefWidth="160"/>
                    <TableColumn fx:id="colEmail"    text="Email"    prefWidth="240"/>
                    <TableColumn fx:id="colRole"     text="Role"     prefWidth="110"/>
                    <TableColumn fx:id="colStatus"   text="Status"   prefWidth="100"/>
                    <TableColumn fx:id="colXp"       text="XP"       prefWidth="75"/>
                    <TableColumn fx:id="colActions"  text="Actions"  prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="No users found." styleClass="table-placeholder"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

</BorderPane>
