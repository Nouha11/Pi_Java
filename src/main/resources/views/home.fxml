<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f8fafc; -fx-background: #f8fafc; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.HomeController">

    <VBox spacing="30.0" style="-fx-padding: 30 40;">

        <HBox style="-fx-background-color: linear-gradient(to right, #0f172a, #312e81); -fx-background-radius: 8; -fx-padding: 40 40; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);">
            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" text="Study Smarter. Level Up." />
                <Label style="-fx-font-size: 14px; -fx-text-fill: #cbd5e1; -fx-wrap-text: true; -fx-max-width: 600;" text="Experience the full power of the NOVA ecosystem right from your desktop. Select a module below to begin your session and earn XP." />

                <HBox spacing="12.0" style="-fx-padding: 15 0 0 0;" alignment="CENTER_LEFT">
                    <Button onAction="#handleStartLearning" style="-fx-background-color: #ffffff; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 8 20; -fx-background-radius: 4; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 5, 0, 0, 2);" text="▶  Explore Courses" />
                    <Button onAction="#handleViewLeaderboard" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 8 20; -fx-background-radius: 4; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 4; -fx-cursor: hand;" text="📊  View Leaderboard" />
                </HBox>
            </VBox>
        </HBox>

        <HBox spacing="20.0">
            <VBox fx:id="cardCourses" onMouseClicked="#goToCourses" spacing="12.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 25; -fx-cursor: hand; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                <ImageView fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/nova-logo.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Interactive Courses" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;" text="Resume your structured learning modules and track your overall progress." />
            </VBox>

            <VBox fx:id="cardForum" onMouseClicked="#goToForum" spacing="12.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 25; -fx-cursor: hand; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                <ImageView fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/nova-logo.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="AI Peer Forum" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;" text="Collaborate, ask questions, upvote answers, and tutor your peers." />
            </VBox>

            <VBox fx:id="cardLibrary" onMouseClicked="#goToLibrary" spacing="12.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 25; -fx-cursor: hand; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                <ImageView fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/nova-logo.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Digital Library" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;" text="Access digital books, research papers, and request physical book loans." />
            </VBox>
        </HBox>

        <HBox spacing="20.0">
            <VBox fx:id="cardQuiz" onMouseClicked="#goToQuiz" spacing="12.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 25; -fx-cursor: hand; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                <ImageView fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/nova-logo.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Skill Quizzes" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;" text="Test your knowledge, beat the clock, and unlock achievements." />
            </VBox>

            <VBox fx:id="cardGames" onMouseClicked="#goToGames" spacing="12.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 25; -fx-cursor: hand; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                <ImageView fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/nova-logo.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Gamification Hub" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;" text="Play educational mini-games to boost your focus and earn coins." />
            </VBox>

            <VBox fx:id="cardRewards" onMouseClicked="#goToRewards" spacing="12.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 25; -fx-cursor: hand; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                <ImageView fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/nova-logo.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Rewards Store" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;" text="Trade your hard-earned NOVA coins for real-world rewards and perks." />
            </VBox>
        </HBox>

    </VBox>
</ScrollPane>