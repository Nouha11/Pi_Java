<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.HomeController">

    <VBox spacing="40.0" style="-fx-padding: 40 50 60 50;">

        <HBox prefHeight="380.0" styleClass="hero-banner">

            <StackPane HBox.hgrow="ALWAYS" style="-fx-background-radius: 16 0 0 16;">

                <Pane fx:id="animationPane" prefWidth="600.0" prefHeight="340.0" />

                <VBox alignment="BOTTOM_LEFT" spacing="15" style="-fx-padding: 30;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="🌍 Join 1,245 students currently online." style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: rgba(15,23,42,0.6); -fx-padding: 8 16; -fx-background-radius: 20;" />
                    </HBox>
                </VBox>
            </StackPane>

            <VBox prefWidth="420.0" spacing="25.0" styleClass="hero-banner-right" style="-fx-padding: 50 45;">
                <Label text="Learn with Nova" style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: 900;" />
                <Label text="Dive into interactive modules, collaborate with peers in real-time, and track your academic journey all in one place." wrapText="true" style="-fx-text-fill: #cbd5e1; -fx-font-size: 16px; -fx-line-spacing: 8px;" />
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#handleStartLearning" maxWidth="Infinity" styleClass="action-btn" text="Explore Courses" />
            </VBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
            <Label text="Active Modules" styleClass="text-primary" style="-fx-font-size: 24px; -fx-font-weight: 900;" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <HBox spacing="25.0">

            <VBox fx:id="cardCourses" onMouseClicked="#goToCourses" prefWidth="230.0" prefHeight="280.0" styleClass="modern-card">
                <StackPane prefHeight="220.0" styleClass="modern-card-image-container">
                    <ImageView fitWidth="180.0" fitHeight="180.0" preserveRatio="true">
                        <image><Image url="@../images/courses.png" /></image>
                    </ImageView>
                </StackPane>
                <VBox alignment="CENTER" prefHeight="60.0">
                    <Label text="Interactive Courses" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold; -fx-font-size: 15px;" />
                </VBox>
            </VBox>

            <VBox fx:id="cardForum" onMouseClicked="#goToForum" prefWidth="230.0" prefHeight="280.0" styleClass="modern-card">
                <StackPane prefHeight="220.0" styleClass="modern-card-image-container">
                    <ImageView fitWidth="190.0" fitHeight="190.0" preserveRatio="true">
                        <image><Image url="@../images/forum.png" /></image>
                    </ImageView>
                </StackPane>
                <VBox alignment="CENTER" prefHeight="60.0">
                    <Label text="Peer Forum" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold; -fx-font-size: 15px;" />
                </VBox>
            </VBox>

            <VBox fx:id="cardLibrary" onMouseClicked="#goToLibrary" prefWidth="230.0" prefHeight="280.0" styleClass="modern-card">
                <StackPane prefHeight="220.0" styleClass="modern-card-image-container">
                    <ImageView fitWidth="170.0" fitHeight="170.0" preserveRatio="true">
                        <image><Image url="@../images/library.png" /></image>
                    </ImageView>
                </StackPane>
                <VBox alignment="CENTER" prefHeight="60.0">
                    <Label text="Digital Library" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold; -fx-font-size: 15px;" />
                </VBox>
            </VBox>

            <VBox fx:id="cardGames" onMouseClicked="#goToGames" prefWidth="230.0" prefHeight="280.0" styleClass="modern-card">
                <StackPane prefHeight="220.0" styleClass="modern-card-image-container">
                    <ImageView fitWidth="190.0" fitHeight="190.0" preserveRatio="true">
                        <image><Image url="@../images/gamification.png" /></image>
                    </ImageView>
                </StackPane>
                <VBox alignment="CENTER" prefHeight="60.0">
                    <Label text="Gamification Hub" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold; -fx-font-size: 15px;" />
                </VBox>
            </VBox>

            <VBox fx:id="cardQuiz" onMouseClicked="#goToQuiz" prefWidth="230.0" prefHeight="280.0" styleClass="modern-card">
                <StackPane prefHeight="220.0" styleClass="modern-card-image-container">
                    <ImageView fitWidth="170.0" fitHeight="170.0" preserveRatio="true">
                        <image><Image url="@../images/quiz.png" /></image>
                    </ImageView>
                </StackPane>
                <VBox alignment="CENTER" prefHeight="60.0">
                    <Label text="Skill Quizzes" style="-fx-text-fill: #f8fafc; -fx-font-weight: bold; -fx-font-size: 15px;" />
                </VBox>
            </VBox>

        </HBox>

    </VBox>
</ScrollPane>