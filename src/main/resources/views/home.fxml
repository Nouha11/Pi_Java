<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-control-inner-background: #f8fafc; -fx-border-width: 0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.NovaDashboardController">

    <stylesheets>
        <URL value="@../css/app.css" />
    </stylesheets>

    <content>
        <VBox alignment="TOP_CENTER" spacing="40.0">
            <padding>
                <Insets bottom="60.0" left="80.0" right="80.0" top="50.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: linear-gradient(to right bottom, #0f172a, #1e293b); -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 20, 0, 0, 10);">
                    <children>
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-font-weight: 900; -fx-font-size: 38px; -fx-text-fill: white;" text="Level up your learning." />
                                <Label style="-fx-font-size: 16px; -fx-text-fill: #94a3b8; -fx-max-width: 450;" text="Join thousands of students tutoring, playing, and climbing the ranks in the NOVA ecosystem." wrapText="true"/>
                                <Region prefHeight="10.0" />
                                <Button style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 24 12 24; -fx-background-radius: 8; -fx-cursor: hand;" text="Continue Current Quest" />
                            </children>
                        </VBox>

                        <StackPane style="-fx-min-width: 250; -fx-min-height: 200; -fx-background-radius: 16;">
                            <Label style="-fx-font-size: 80px;" text="🚀" />
                        </StackPane>
                    </children>
                </HBox>

                <GridPane alignment="CENTER" hgap="30.0" vgap="30.0">
                    <children>

                        <Button mnemonicParsing="false" onAction="#handleShowStudySessions" prefHeight="280.0" prefWidth="350.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #e0e7ff, #c7d2fe); -fx-min-height: 160; -fx-background-radius: 11 11 0 0;">
                                        <Label style="-fx-font-size: 55px;" text="📚" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Interactive Courses" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Resume your structured learning modules." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowForum" prefHeight="280.0" prefWidth="350.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #fce7f3, #fbcfe8); -fx-min-height: 160; -fx-background-radius: 11 11 0 0;">
                                        <Label style="-fx-font-size: 55px;" text="💬" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Peer Forum" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Collaborate, ask questions, and tutor peers." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowLibrary" prefHeight="280.0" prefWidth="350.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #dcfce7, #bbf7d0); -fx-min-height: 160; -fx-background-radius: 11 11 0 0;">
                                        <Label style="-fx-font-size: 55px;" text="🏛️" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Digital Library" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Access books, research, and premium assets." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowQuiz" prefHeight="280.0" prefWidth="350.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #fef08a, #fde047); -fx-min-height: 160; -fx-background-radius: 11 11 0 0;">
                                        <Label style="-fx-font-size: 55px;" text="⚡" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Smart Quizzes" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Test your skills with automated grading." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowGamification" prefHeight="280.0" prefWidth="350.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #ffedd5, #fed7aa); -fx-min-height: 160; -fx-background-radius: 11 11 0 0;">
                                        <Label style="-fx-font-size: 55px;" text="🎯" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Educational Arcade" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Reinforce knowledge through interactive play." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowRewards" prefHeight="280.0" prefWidth="350.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #f3e8ff, #e9d5ff); -fx-min-height: 160; -fx-background-radius: 11 11 0 0;">
                                        <Label style="-fx-font-size: 55px;" text="🎖️" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Rewards &amp; Badges" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Track your progress and climb leaderboards." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                    </children>
                </GridPane>
            </children>
        </VBox>
    </content>
</ScrollPane>