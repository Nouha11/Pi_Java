<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-control-inner-background: #f8fafc; -fx-border-width: 0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.NovaDashboardController">

    <stylesheets>
        <URL value="@../css/app.css" />
    </stylesheets>

    <content>
        <VBox alignment="TOP_CENTER" spacing="40.0">
            <padding>
                <Insets bottom="60.0" left="80.0" right="80.0" top="50.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: linear-gradient(to right bottom, #0f172a, #2e1065); -fx-background-radius: 20; -fx-padding: 45; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 20, 0, 0, 10);">
                    <children>
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-font-weight: 900; -fx-font-size: 42px; -fx-text-fill: white;" text="Study Smarter. Level Up." />
                                <Label style="-fx-font-size: 16px; -fx-text-fill: #cbd5e1; -fx-max-width: 500;" text="Experience the full power of the NOVA ecosystem right from your desktop. Select a module below to begin your session." wrapText="true"/>
                                <Region prefHeight="10.0" />
                                <HBox spacing="15">
                                    <Button style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-background-radius: 8; -fx-cursor: hand;" text="Explore Courses" />
                                    <Button style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 28 12 28; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 8; -fx-cursor: hand;" text="View Leaderboard" />
                                </HBox>
                            </children>
                        </VBox>

                        <StackPane style="-fx-min-width: 200; -fx-min-height: 200; -fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 100;">
                            <SVGPath content="M12 2L2 22h20L12 2zm0 6l5.5 11h-11L12 8z" fill="#8b5cf6" scaleX="4" scaleY="4" />
                        </StackPane>
                    </children>
                </HBox>

                <GridPane alignment="CENTER" hgap="30.0" vgap="30.0">
                    <children>

                        <Button mnemonicParsing="false" onAction="#handleShowStudySessions" prefHeight="260.0" prefWidth="360.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: #dcfce7; -fx-min-height: 140; -fx-background-radius: 11 11 0 0;">
                                        <SVGPath content="M21 4H7a2 2 0 0 0-2 2v14c0 1.1.9 2 2 2h14V4zM5 18V6a2 2 0 0 0-2 2v14c0 1.1.9 2 2 2h14v-2H5z" fill="#166534" scaleX="2.5" scaleY="2.5" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Interactive Courses" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Resume your structured learning modules." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowForum" prefHeight="260.0" prefWidth="360.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: #dbeafe; -fx-min-height: 140; -fx-background-radius: 11 11 0 0;">
                                        <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="#1e3a8a" scaleX="2.5" scaleY="2.5" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="AI Peer Forum" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Collaborate, ask questions, and tutor peers." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowLibrary" prefHeight="260.0" prefWidth="360.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: #ccfbf1; -fx-min-height: 140; -fx-background-radius: 11 11 0 0;">
                                        <SVGPath content="M12 1L3 5v2h18V5l-9-4zm0 2.18l5.46 2.43H6.54L12 3.18zM4 10v7h2v-7H4zm6 0v7h2v-7h-2zm6 0v7h2v-7h-2zM2 19v2h20v-2H2z" fill="#0f766e" scaleX="2.5" scaleY="2.5" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Digital Library" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Access books, research, and premium assets." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowQuiz" prefHeight="260.0" prefWidth="360.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: #f3e8ff; -fx-min-height: 140; -fx-background-radius: 11 11 0 0;">
                                        <SVGPath content="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="#6b21a8" scaleX="2.5" scaleY="2.5" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Smart Quizzes" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Test your skills with automated grading." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowGamification" prefHeight="260.0" prefWidth="360.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: #fef9c3; -fx-min-height: 140; -fx-background-radius: 11 11 0 0;">
                                        <SVGPath content="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 9 18.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" fill="#a16207" scaleX="2.5" scaleY="2.5" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Educational Arcade" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Reinforce knowledge through interactive play." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#handleShowRewards" prefHeight="260.0" prefWidth="360.0" styleClass="app-card" style="-fx-padding: 0;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <graphic>
                                <VBox alignment="TOP_CENTER" spacing="0">
                                    <StackPane style="-fx-background-color: #ffe4e6; -fx-min-height: 140; -fx-background-radius: 11 11 0 0;">
                                        <SVGPath content="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="#be123c" scaleX="2.5" scaleY="2.5" />
                                    </StackPane>
                                    <VBox alignment="CENTER_LEFT" spacing="6.0" style="-fx-padding: 20;">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #0f172a;" text="Rewards System" />
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Track your progress and climb leaderboards." wrapText="true" />
                                    </VBox>
                                </VBox>
                            </graphic>
                        </Button>

                    </children>
                </GridPane>
            </children>
        </VBox>
    </content>
</ScrollPane>