<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="660" prefWidth="920" styleClass="module-pane"
      stylesheets="@../../css/quiz.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="controllers.quiz.QuizPlayListController">

    <!-- TOOLBAR -->
    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar">
        <padding><Insets bottom="14" left="20" right="20" top="14"/></padding>
        <Label styleClass="toolbar-title" text="🎯  Smart Quizzes"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="txtSearch" promptText="🔍  Search…"
                   styleClass="search-field" prefWidth="180"
                   onKeyReleased="#handleFilterSort"/>
        <ComboBox fx:id="cmbSort" promptText="Sort by…"
                  styleClass="sort-combo" prefWidth="155"
                  onAction="#handleFilterSort"/>
    </HBox>

    <!-- FILTER BAR -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="filter-bar">
        <padding><Insets bottom="10" left="20" right="20" top="10"/></padding>
        <Label styleClass="filter-label" text="Questions:"/>
        <TextField fx:id="txtMinQ" promptText="Min" styleClass="filter-num-field"
                   prefWidth="56" onKeyReleased="#handleFilterSort"/>
        <Label styleClass="filter-label" text="–"/>
        <TextField fx:id="txtMaxQ" promptText="Max" styleClass="filter-num-field"
                   prefWidth="56" onKeyReleased="#handleFilterSort"/>
        <Label styleClass="filter-label" text="Description:"/>
        <ComboBox fx:id="cmbDesc" styleClass="sort-combo" prefWidth="100"
                  onAction="#handleFilterSort"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleClearFilters" styleClass="btn-ghost-sm" text="✕  Clear"/>
    </HBox>

    <!-- CARD GRID -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent;-fx-background:transparent;"
                VBox.vgrow="ALWAYS">
        <VBox>
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <FlowPane fx:id="cardsPane" hgap="16" vgap="16" styleClass="cards-pane"/>
        </VBox>
    </ScrollPane>

    <!-- STATUS BAR -->
    <HBox styleClass="status-bar">
        <padding><Insets bottom="8" left="20" right="20" top="8"/></padding>
        <Label fx:id="lblStatus" styleClass="status-label" text=""/>
    </HBox>

</VBox>
