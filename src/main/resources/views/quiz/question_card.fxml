<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="question-card"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="question-header">
        <padding><Insets bottom="10" left="16" right="16" top="10"/></padding>
        <Label style="-fx-background-color:#ddd6fe;-fx-background-radius:8;
                      -fx-padding:4 10 4 10;-fx-font-size:11px;" text="❓"/>
        <Label fx:id="lblQuestionNumber" styleClass="question-label" text="Question 1"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRemoveQuestion" styleClass="btn-danger" text="Remove"/>
    </HBox>

    <VBox spacing="10">
        <padding><Insets bottom="16" left="16" right="16" top="12"/></padding>

        <Label styleClass="field-label" text="Question Text *"/>
        <TextArea fx:id="txtQuestionText" prefRowCount="2"
                  promptText="Enter the question…" wrapText="true"/>
        <Label fx:id="errQuestionText" managed="false" styleClass="field-error"
               text=" " visible="false"/>

        <HBox spacing="14">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="XP Value *"/>
                <TextField fx:id="txtXpValue" promptText="e.g. 10"/>
                <Label fx:id="errXpValue" managed="false" styleClass="field-error"
                       text=" " visible="false"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Difficulty *"/>
                <ComboBox fx:id="cbDifficulty" maxWidth="Infinity"/>
                <Label fx:id="errDifficulty" managed="false" styleClass="field-error"
                       text=" " visible="false"/>
            </VBox>
        </HBox>

        <!-- Choices header -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding:4 0 0 0;">
            <Label styleClass="field-label" text="Answer Choices"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAddChoice" onAction="#handleAddChoice"
                    styleClass="btn-add-choice" text="＋ Add Choice"/>
        </HBox>
        <Label fx:id="errChoices" managed="false" styleClass="field-error"
               text=" " visible="false"/>

        <VBox fx:id="choicesContainer" spacing="8"/>
    </VBox>
</VBox>
