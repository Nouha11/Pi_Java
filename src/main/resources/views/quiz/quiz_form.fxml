<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720" prefWidth="700" styleClass="form-pane"
      stylesheets="@../../css/quiz.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="controllers.quiz.QuizFormController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" styleClass="form-header">
        <padding><Insets bottom="18" left="24" right="24" top="18"/></padding>
        <Label fx:id="formTitle" styleClass="form-title" text="New Quiz"/>
    </HBox>

    <!-- ERROR BANNER -->
    <Label fx:id="lblError" managed="false" maxWidth="660" styleClass="error-banner"
           visible="false" wrapText="true">
        <VBox.margin><Insets left="20" right="20" top="12"/></VBox.margin>
    </Label>

    <!-- SCROLLABLE BODY -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                style="-fx-background-color:transparent;-fx-background:transparent;"
                vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
        <VBox spacing="16">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>

            <!-- ── QUIZ INFO CARD ── -->
            <VBox spacing="12" styleClass="section-card">
                <padding><Insets bottom="20" left="20" right="20" top="16"/></padding>

                <Label styleClass="section-title" text="Quiz Details"/>

                <VBox spacing="4">
                    <Label styleClass="field-label" text="Title *"/>
                    <TextField fx:id="txtTitle" maxWidth="Infinity"
                               promptText="e.g. Java Basics Quiz  (3–255 chars)"/>
                    <Label fx:id="errTitle" managed="false" styleClass="field-error"
                           text=" " visible="false"/>
                </VBox>

                <VBox spacing="4">
                    <Label styleClass="field-label" text="Description (optional)"/>
                    <TextArea fx:id="txtDescription" maxWidth="Infinity" prefRowCount="3"
                              promptText="Brief description of this quiz…" wrapText="true"/>
                    <Label fx:id="errDescription" managed="false" styleClass="field-error"
                           text=" " visible="false"/>
                </VBox>
            </VBox>

            <!-- ── QUESTIONS SECTION ── -->
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#1e2a5e;"
                           text="Questions"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#handleAddQuestion" styleClass="btn-add-question"
                            text="＋  Add Question"/>
                </HBox>

                <VBox fx:id="questionsContainer" spacing="14"/>

                <Label fx:id="lblNoQuestions"
                       style="-fx-text-fill:#a0aec0; -fx-font-style:italic; -fx-font-size:13px;"
                       text="No questions yet — click '＋ Add Question' to begin."/>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- FOOTER -->
    <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="form-footer">
        <padding><Insets bottom="16" left="24" right="24" top="14"/></padding>
        <Button cancelButton="true" onAction="#handleCancel" styleClass="btn-ghost" text="Cancel"/>
        <Button fx:id="btnSave" defaultButton="true" onAction="#handleSave"
                styleClass="btn-primary" text="💾  Save Quiz"/>
    </HBox>

</VBox>
