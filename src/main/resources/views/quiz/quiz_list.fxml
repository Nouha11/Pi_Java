<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="620" prefWidth="860" styleClass="module-pane"
      stylesheets="@../../css/quiz.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="controllers.quiz.QuizListController">

    <!-- TOOLBAR -->
    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar">
        <padding><Insets bottom="14" left="20" right="20" top="14"/></padding>
        <Label styleClass="toolbar-title" text="📝  Quizzes"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="txtSearch" promptText="🔍  Search quizzes…"
                   styleClass="search-field" prefWidth="200"
                   onKeyReleased="#handleFilterSort"/>
        <ComboBox fx:id="cmbSort" promptText="Sort by…"
                  styleClass="sort-combo" prefWidth="160"
                  onAction="#handleFilterSort"/>
        <Button onAction="#handleCreate" styleClass="btn-primary" text="＋  New Quiz"/>
    </HBox>

    <!-- CARD GRID -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent;-fx-background:transparent;"
                VBox.vgrow="ALWAYS">
        <VBox>
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <FlowPane fx:id="cardsPane" hgap="16" vgap="16"
                      styleClass="cards-pane"/>
        </VBox>
    </ScrollPane>

    <!-- STATUS BAR -->
    <HBox styleClass="status-bar">
        <padding><Insets bottom="8" left="20" right="20" top="8"/></padding>
        <Label fx:id="lblStatus" styleClass="status-label" text=""/>
    </HBox>

</VBox>
