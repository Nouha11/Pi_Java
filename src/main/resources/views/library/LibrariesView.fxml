<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.LibrariesController"
            style="-fx-background-color: #0f172a;">
    <stylesheets>
        <URL value="@../../css/library.css"/>
    </stylesheets>

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: linear-gradient(to right, #0f172a, #1e293b);
                     -fx-padding: 14 24; -fx-border-color: #1e293b; -fx-border-width: 0 0 1 0;">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-padding: 7 16; -fx-cursor: hand;
                           -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8;"/>
            <Separator orientation="VERTICAL" style="-fx-background-color: rgba(255,255,255,0.15);"/>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="lblBookName" text="Book"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Select a library to borrow from — click map to set your location"
                       style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.5);"/>
            </VBox>
            <Button text="📍 Set My Location" onAction="#handleGetLocation"
                    style="-fx-background-color: linear-gradient(to right, #3b82f6, #6366f1);
                           -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;
                           -fx-padding: 8 18; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.4), 8, 0, 0, 2);"/>
            <Button text="⊞ Fit All" onAction="#handleFitAll"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;
                           -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8;"/>
            <Label fx:id="lblLocationStatus" text=""
                   style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.6);"/>
        </HBox>
    </top>

    <!-- Main: Map + sidebar -->
    <center>
        <HBox>
            <!-- Full-height map -->
            <WebView fx:id="mapView" HBox.hgrow="ALWAYS"/>

            <!-- Compact library sidebar -->
            <VBox prefWidth="300" minWidth="280"
                  style="-fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 0 0 0 1;">

                <!-- Sidebar header -->
                <VBox style="-fx-padding: 16 16 12 16; -fx-border-color: #1e293b; -fx-border-width: 0 0 1 0;">
                    <Label text="Nearby Libraries"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="lblSortInfo" text="Sorted by name"
                           style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.4);"/>
                </VBox>

                <!-- Library cards list -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: #0f172a;
                                   -fx-border-color: transparent;">
                    <VBox fx:id="librariesContainer" spacing="8" style="-fx-padding: 12;"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
