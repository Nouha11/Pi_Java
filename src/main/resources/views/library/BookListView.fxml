<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.BookListController"
            style="-fx-background-color: #f0f4f8;">
    <stylesheets>
        <URL value="@../../css/library.css"/>
    </stylesheets>

    <top>
        <!-- Hero section with gradient + animated title -->
        <VBox fx:id="heroSection" spacing="0">

            <!-- Main hero banner -->
            <VBox style="-fx-background-color: linear-gradient(to bottom right, #0f0c29, #302b63, #24243e);
                         -fx-padding: 36 40 32 40;" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Nova Library"
                               style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Discover, purchase and read books from our curated collection"
                               style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.65);"/>
                        <!-- Stats row -->
                        <HBox spacing="24" style="-fx-padding: 8 0 0 0;">
                            <VBox alignment="CENTER" spacing="2">
                                <Label fx:id="statusLabel" text="0 books"
                                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #a78bfa;"/>
                                <Label text="Available" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                            </VBox>
                            <Separator orientation="VERTICAL" style="-fx-background-color: rgba(255,255,255,0.15);"/>
                            <VBox alignment="CENTER" spacing="2">
                                <Label text="PDF" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #34d399;"/>
                                <Label text="Digital" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                            </VBox>
                            <Separator orientation="VERTICAL" style="-fx-background-color: rgba(255,255,255,0.15);"/>
                            <VBox alignment="CENTER" spacing="2">
                                <Label text="AI" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #f472b6;"/>
                                <Label text="Assistant" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Search box on the right -->
                    <VBox spacing="10" prefWidth="360">
                        <HBox spacing="8">
                            <TextField fx:id="searchField" promptText="Search books, authors..."
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: rgba(255,255,255,0.15);
                                              -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 10;
                                              -fx-background-radius: 10; -fx-padding: 11 14;
                                              -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.5);
                                              -fx-font-size: 13;"/>
                            <Button text="Search" onAction="#applyFilters"
                                    style="-fx-background-color: white;
                                           -fx-text-fill: #4f46e5; -fx-font-weight: bold;
                                           -fx-background-radius: 10; -fx-padding: 11 20; -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 6, 0, 0, 2);"/>
                        </HBox>
                        <ComboBox fx:id="filterType" maxWidth="Infinity"
                                  style="-fx-background-color: rgba(255,255,255,0.15);
                                         -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 10;
                                         -fx-background-radius: 10; -fx-padding: 4 8;
                                         -fx-text-fill: white;"/>
                    </VBox>
                </HBox>
            </VBox>

            <HBox style="-fx-background-color: linear-gradient(to right, #fef9c3, #fef3c7);
                         -fx-padding: 14 40; -fx-border-color: #fde68a; -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT" spacing="16">
                <Label text="[TOP]" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #92400e;
                                           -fx-background-color: #fbbf24; -fx-background-radius: 6;
                                           -fx-padding: 3 8;"/>
                <Label text="Best Sellers"
                       style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #92400e;"/>
                <Separator orientation="VERTICAL" style="-fx-background-color: #fbbf24;"/>
                <HBox fx:id="bestSellersRow" spacing="14"/>
            </HBox>

        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox style="-fx-padding: 28 32;">
                <FlowPane fx:id="booksGrid" hgap="22" vgap="22"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
