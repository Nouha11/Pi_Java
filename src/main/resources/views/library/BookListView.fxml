<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.BookListController"
            style="-fx-background-color: #f8f9fa;">

    <top>
        <VBox style="-fx-background-color: #ffffff; -fx-border-color: #dee2e6;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
            <Label text="📚 Library — Browse Books"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
            <Label text="Find a book to borrow or purchase"
                   style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Search + filter bar -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 14 20; -fx-background-radius: 8;
                         -fx-border-color: #dee2e6; -fx-border-radius: 8;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
                <TextField fx:id="searchField" promptText="Search by title, author, ISBN..."
                           prefWidth="280"
                           style="-fx-border-color: #dee2e6; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 8 10;"/>
                <ComboBox fx:id="filterType" prefWidth="140"
                          style="-fx-border-color: #dee2e6; -fx-border-radius: 6;"/>
                <Button text="🔍 Search" onAction="#applyFilters"
                        style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                               -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Label fx:id="statusLabel" text="" HBox.hgrow="ALWAYS"
                       style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
            </HBox>

            <!-- Book table -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8;
                         -fx-border-color: #dee2e6;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);"
                  VBox.vgrow="ALWAYS">

                <TableView fx:id="bookTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colTitle"  text="Title"  prefWidth="240"/>
                        <TableColumn fx:id="colAuthor" text="Author" prefWidth="160"/>
                        <TableColumn fx:id="colIsbn"   text="ISBN"   prefWidth="130"/>
                        <TableColumn fx:id="colPrice"  text="Price"  prefWidth="80"/>
                        <TableColumn fx:id="colType"   text="Type"   prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 40;">
                            <Label text="📚" style="-fx-font-size: 40;"/>
                            <Label text="No books found" style="-fx-font-size: 16; -fx-text-fill: #6c757d;"/>
                        </VBox>
                    </placeholder>
                </TableView>

                <!-- Footer -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 12 20; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;
                             -fx-background-color: #f8f9fa; -fx-background-radius: 0 0 8 8;">
                    <Button text="👁 View Book" onAction="#handleViewBook"
                            style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 6;
                                   -fx-padding: 8 18; -fx-cursor: hand;"/>
                    <Label text="Double-click a book or select and click View"
                           style="-fx-font-size: 12; -fx-text-fill: #adb5bd;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
