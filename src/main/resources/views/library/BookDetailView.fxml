<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.BookDetailController"
            style="-fx-background-color: #f0f4f8;">
    <stylesheets>
        <URL value="@../../css/library.css"/>
    </stylesheets>

    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #1e1b4b, #312e81, #4338ca);
                     -fx-padding: 22 32 22 32;" spacing="4">
            <Label fx:id="lblTitle" text="Book Title"
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Home › Books ›" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.6);"/>
                <Label fx:id="lblBreadcrumb" text="Book"
                       style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.9);"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="24" style="-fx-padding: 24;" alignment="TOP_LEFT">

            <!-- LEFT: cover + action buttons -->
            <VBox spacing="16" prefWidth="280">
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      alignment="CENTER" spacing="16">

                    <Label fx:id="lblCoverPlaceholder" text="📖"
                           style="-fx-font-size: 80; -fx-text-fill: #dee2e6;"/>

                    <Label fx:id="lblPrice"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #198754;"/>

                    <Label fx:id="lblTypeBadge" text="Physical"
                           style="-fx-background-color: #d1ecf1; -fx-text-fill: #0c5460;
                                  -fx-padding: 4 12; -fx-background-radius: 20; -fx-font-size: 12;"/>

                    <Separator/>

                    <!-- Buy Digital (only shown for digital books) -->
                    <Button fx:id="btnBuyDigital" text="🛒 Buy Digital Copy"
                            onAction="#handleBuyDigital" maxWidth="Infinity"
                            style="-fx-background-color: #198754; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 6;
                                   -fx-padding: 10 16; -fx-cursor: hand;"/>

                    <!-- Borrow from Library -->
                    <Button fx:id="btnBorrow" text="📚 Borrow from Library"
                            onAction="#handleBorrow" maxWidth="Infinity"
                            style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 6;
                                   -fx-padding: 10 16; -fx-cursor: hand;"/>

                    <Button text="← Back to Books" onAction="#handleBack" maxWidth="Infinity"
                            style="-fx-background-color: #f8f9fa; -fx-text-fill: #495057;
                                   -fx-border-color: #dee2e6; -fx-border-radius: 6;
                                   -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </VBox>
            </VBox>

            <!-- RIGHT: book details -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

                    <Label text="Book Details"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #212529;
                                  -fx-padding: 0 0 12 0; -fx-border-color: #dee2e6;
                                  -fx-border-width: 0 0 1 0;"/>

                    <GridPane hgap="20" vgap="12" style="-fx-padding: 16 0 0 0;">
                        <Label text="Title:"    GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #6c757d;" minWidth="100"/>
                        <Label fx:id="detailTitle"  GridPane.rowIndex="0" GridPane.columnIndex="1"
                               style="-fx-text-fill: #212529; -fx-font-size: 14;" wrapText="true"/>

                        <Label text="Author:"  GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                        <Label fx:id="detailAuthor" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               style="-fx-text-fill: #212529;"/>

                        <Label text="ISBN:"    GridPane.rowIndex="2" GridPane.columnIndex="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                        <Label fx:id="detailIsbn"   GridPane.rowIndex="2" GridPane.columnIndex="1"
                               style="-fx-text-fill: #212529;"/>

                        <Label text="Price:"   GridPane.rowIndex="3" GridPane.columnIndex="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                        <Label fx:id="detailPrice"  GridPane.rowIndex="3" GridPane.columnIndex="1"
                               style="-fx-text-fill: #198754; -fx-font-weight: bold;"/>

                        <Label text="Format:"  GridPane.rowIndex="4" GridPane.columnIndex="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                        <Label fx:id="detailType"   GridPane.rowIndex="4" GridPane.columnIndex="1"
                               style="-fx-text-fill: #212529;"/>
                    </GridPane>
                </VBox>

                <!-- Get this book section -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      spacing="12">
                    <Label text="Get this book"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <HBox spacing="12">
                        <Button fx:id="btnBuyDigital2" text="🛒 Purchase Digital Copy"
                                onAction="#handleBuyDigital"
                                style="-fx-background-color: #198754; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-padding: 10 18; -fx-cursor: hand;"/>
                        <Button text="🏛 Borrow from Library" onAction="#handleBorrow"
                                style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-padding: 10 18; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
