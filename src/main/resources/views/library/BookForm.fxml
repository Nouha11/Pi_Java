<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #f8f9fa; -fx-min-width: 480;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.library.BookFormController">

    <!-- Header -->
    <VBox style="-fx-background-color: #ffffff; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;
                 -fx-padding: 20 24;">
        <Label fx:id="formTitle" text="New Book"
               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
        <Label text="Fill in the details below to add a book to the catalog."
               style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
    </VBox>

    <!-- Form Body -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #f8f9fa;">

            <!-- Card -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8;
                         -fx-border-color: #dee2e6; -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
                <Label text="Book Information"
                       style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #212529; -fx-padding: 0 0 12 0;"/>

                <GridPane hgap="16" vgap="12">
                    <!-- Title -->
                    <Label text="Title *" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;" minWidth="120"/>
                    <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="3" HBox.hgrow="ALWAYS">
                        <TextField fx:id="txtTitle" promptText="Enter book title" prefWidth="300"
                                   style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 10;"/>
                        <Label fx:id="errTitle" style="-fx-text-fill: #dc3545; -fx-font-size: 11;" visible="false"/>
                    </VBox>

                    <!-- Author -->
                    <Label text="Author *" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                    <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" spacing="3">
                        <TextField fx:id="txtAuthor" promptText="Author name"
                                   style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 10;"/>
                        <Label fx:id="errAuthor" style="-fx-text-fill: #dc3545; -fx-font-size: 11;" visible="false"/>
                    </VBox>

                    <!-- ISBN -->
                    <Label text="ISBN" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                    <TextField fx:id="txtIsbn" promptText="978-..." GridPane.rowIndex="2" GridPane.columnIndex="1"
                               style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 10;"/>

                    <!-- Price -->
                    <Label text="Price (USD) *" GridPane.rowIndex="3" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                    <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="3">
                        <TextField fx:id="txtPrice" promptText="0.00"
                                   style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 10;"/>
                        <Label fx:id="errPrice" style="-fx-text-fill: #dc3545; -fx-font-size: 11;" visible="false"/>
                    </VBox>

                    <!-- Type -->
                    <Label text="Type *" GridPane.rowIndex="4" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                    <VBox GridPane.rowIndex="4" GridPane.columnIndex="1" spacing="3">
                        <ComboBox fx:id="cbType" prefWidth="300"
                                  style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        <Label fx:id="errType" style="-fx-text-fill: #dc3545; -fx-font-size: 11;" visible="false"/>
                    </VBox>

                    <!-- Cover Image -->
                    <Label text="Cover Image" GridPane.rowIndex="5" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                    <TextField fx:id="txtCoverImage" promptText="uploads/books/cover.jpg"
                               GridPane.rowIndex="5" GridPane.columnIndex="1"
                               style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 10;"/>

                    <!-- PDF URL -->
                    <Label text="PDF URL" GridPane.rowIndex="6" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                    <TextField fx:id="txtPdfUrl" promptText="uploads/pdfs/book.pdf"
                               GridPane.rowIndex="6" GridPane.columnIndex="1"
                               style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 10;"/>
                </GridPane>
            </VBox>

            <!-- Error banner -->
            <Label fx:id="lblError"
                   style="-fx-text-fill: #842029; -fx-background-color: #f8d7da; -fx-border-color: #f5c2c7;
                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10 14;
                          -fx-font-size: 13;" visible="false" wrapText="true"/>

            <!-- Buttons -->
            <HBox spacing="10">
                <Button fx:id="btnSave" text="💾 Save Book" onAction="#handleSave"
                        style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button text="✖ Cancel" onAction="#handleCancel"
                        style="-fx-background-color: #6c757d; -fx-text-fill: white;
                               -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
