<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.PaymentFormController"
            style="-fx-background-color: #f8f9fa;">

    <top>
        <VBox style="-fx-background-color: #cfe2ff; -fx-padding: 20 24 20 24;">
            <Label fx:id="lblHeader" text="Complete Payment"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
            <Label text="Home › Books › Purchase › Payment"
                   style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="24" style="-fx-padding: 24;" alignment="TOP_LEFT">

            <!-- LEFT: Stripe embedded form in WebView -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">

                <!-- Status label shown while connecting to Stripe -->
                <Label fx:id="lblStatus" text="Connecting to Stripe..."
                       style="-fx-font-size: 13; -fx-text-fill: #6c757d;" visible="false" managed="false"/>

                <!-- Stripe.js card form renders here -->
                <WebView fx:id="stripeWebView" prefHeight="420" VBox.vgrow="ALWAYS"/>

                <!-- PayPal fallback panel (hidden by default) -->
                <VBox fx:id="paypalFields" alignment="CENTER" spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #dee2e6; -fx-border-radius: 12; -fx-padding: 40;"
                      visible="false" managed="false">
                    <Label text="PayPal" style="-fx-font-size: 48;"/>
                    <Label text="Click below to complete your PayPal payment"
                           style="-fx-font-size: 14; -fx-text-fill: #212529;" wrapText="true"/>
                    <Button text="Pay with PayPal" onAction="#handlePayPal"
                            style="-fx-background-color: #0070ba; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 8;
                                   -fx-padding: 12 32; -fx-cursor: hand;"/>
                </VBox>

                <Button text="Back" onAction="#handleBack"
                        style="-fx-background-color: #f8f9fa; -fx-text-fill: #495057;
                               -fx-border-color: #dee2e6; -fx-border-radius: 6;
                               -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </VBox>

            <!-- RIGHT: Order summary -->
            <VBox prefWidth="260" spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-border-color: #dee2e6; -fx-border-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

                <Label text="Order Summary"
                       style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #212529;
                              -fx-padding: 16 20; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;"/>

                <VBox spacing="12" style="-fx-padding: 16 20;">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="📖" style="-fx-font-size: 24;"/>
                        <VBox spacing="2">
                            <Label fx:id="sideBookTitle" wrapText="true"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                            <Label fx:id="sideBookAuthor"
                                   style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <HBox>
                        <Label text="Book Price" HBox.hgrow="ALWAYS" style="-fx-text-fill: #495057;"/>
                        <Label fx:id="sidePrice" style="-fx-font-weight: bold;"/>
                    </HBox>
                    <HBox>
                        <Label text="Tax (0%)" HBox.hgrow="ALWAYS" style="-fx-text-fill: #495057;"/>
                        <Label text="0.00" style="-fx-font-weight: bold;"/>
                    </HBox>
                    <Separator/>
                    <HBox>
                        <Label text="Total" HBox.hgrow="ALWAYS"
                               style="-fx-font-weight: bold; -fx-font-size: 15;"/>
                        <Label fx:id="sideTotal"
                               style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #198754;"/>
                    </HBox>

                    <Separator/>

                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 6;">
                        <Label fx:id="sideMethodIcon" text="💳" style="-fx-font-size: 20;"/>
                        <VBox spacing="2">
                            <Label text="Payment Method" style="-fx-font-size: 11; -fx-text-fill: #6c757d;"/>
                            <Label fx:id="sideMethodName"
                                   style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #212529;"/>
                        </VBox>
                    </HBox>

                    <!-- Stripe badge -->
                    <VBox alignment="CENTER" style="-fx-padding: 8 0 0 0;">
                        <Label text="Powered by Stripe"
                               style="-fx-font-size: 11; -fx-text-fill: #adb5bd;"/>
                        <Label text="🔒 256-bit SSL encryption"
                               style="-fx-font-size: 11; -fx-text-fill: #adb5bd;"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
