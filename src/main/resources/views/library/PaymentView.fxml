<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.PaymentController"
            style="-fx-background-color: #f8f9fa;">

    <!-- Header -->
    <top>
        <VBox style="-fx-background-color: #ffffff; -fx-border-color: #dee2e6;
                     -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
            <Label text="Payment History"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
            <Label text="All digital book purchases processed through the platform"
                   style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Stats row -->
            <HBox spacing="16">
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 16 20;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Total Payments" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                    <Label fx:id="statTotal" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 16 20;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Completed" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                    <Label fx:id="statCompleted" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #198754;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 16 20;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Failed" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                    <Label fx:id="statFailed" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
                </VBox>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 16 20;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Total Revenue" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                    <Label fx:id="statRevenue" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0d6efd;"/>
                </VBox>
            </HBox>

            <!-- Payments list card -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #dee2e6; -fx-border-radius: 8;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                  VBox.vgrow="ALWAYS">

                <!-- Card header -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 14 20; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                    <Label text="All Payments"
                           style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #212529;"
                           HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh" onAction="#handleRefresh"
                            style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
                </HBox>

                <!-- Scrollable payments list built programmatically by controller -->
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;
                                                      -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="paymentsContainer" spacing="10" style="-fx-padding: 16;"/>
                </ScrollPane>

                <!-- Footer -->
                <HBox style="-fx-padding: 10 20; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;
                             -fx-background-color: #f8f9fa; -fx-background-radius: 0 0 8 8;">
                    <Label fx:id="statusLabel" text="" style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
