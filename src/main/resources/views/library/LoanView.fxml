<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.LoanController"
            style="-fx-background-color: #f8f9fa;">

    <!-- ── TOP HEADER ── -->
    <top>
        <VBox style="-fx-background-color: #ffffff; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;
                     -fx-padding: 16 24 16 24;">
            <Label text="Loan Management"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
            <Label text="Manage book loan requests and approvals"
                   style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24;">

            <!-- Stat Cards -->
            <HBox spacing="16">
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #ffc107; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 14 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statPending" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #ffc107;"/>
                    <Label text="Pending" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #0d6efd; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 14 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statApproved" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0d6efd;"/>
                    <Label text="Approved" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #198754; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 14 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statActive" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #198754;"/>
                    <Label text="Active" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #6c757d; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 14 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statReturned" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                    <Label text="Returned" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #dc3545; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 14 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statRejected" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
                    <Label text="Rejected" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
            </HBox>

            <!-- Card: Table -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8;
                         -fx-border-color: #dee2e6; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                  VBox.vgrow="ALWAYS">

                <!-- Card Header: filter tabs -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-padding: 14 20; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                    <Label text="Filter:" style="-fx-font-size: 13; -fx-text-fill: #495057;"/>
                    <ComboBox fx:id="filterStatus" prefWidth="150"
                              style="-fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    <Button text="↺ Refresh" onAction="#handleRefresh"
                            style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;"/>
                    <Label fx:id="statusLabel" text="" HBox.hgrow="ALWAYS"
                           style="-fx-font-size: 13; -fx-padding: 0 0 0 8;"/>
                </HBox>

                <!-- Table -->
                <TableView fx:id="loanTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colId"        text="ID"        prefWidth="55"/>
                        <TableColumn fx:id="colBook"      text="Book"      prefWidth="190"/>
                        <TableColumn fx:id="colUser"      text="User"      prefWidth="160"/>
                        <TableColumn fx:id="colLibrary"   text="Library"   prefWidth="140"/>
                        <TableColumn fx:id="colStatus"    text="Status"    prefWidth="110"/>
                        <TableColumn fx:id="colRequested" text="Requested" prefWidth="110"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 40;">
                            <Label text="📋" style="-fx-font-size: 40;"/>
                            <Label text="No loans found" style="-fx-font-size: 16; -fx-text-fill: #6c757d;"/>
                        </VBox>
                    </placeholder>
                </TableView>

                <!-- Card Footer: action buttons -->
                <HBox spacing="10"
                      style="-fx-padding: 12 20; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;
                             -fx-background-color: #f8f9fa; -fx-background-radius: 0 0 8 8;">
                    <Button text="✅ Approve" onAction="#handleApprove"
                            style="-fx-background-color: #198754; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 6; -fx-padding: 7 14; -fx-cursor: hand;"/>
                    <Button text="❌ Reject" onAction="#handleReject"
                            style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 6; -fx-padding: 7 14; -fx-cursor: hand;"/>
                    <Button text="→ Mark Active" onAction="#handleMarkActive"
                            style="-fx-background-color: #0dcaf0; -fx-text-fill: #212529; -fx-font-weight: bold;
                                   -fx-background-radius: 6; -fx-padding: 7 14; -fx-cursor: hand;"/>
                    <Button text="↩ Mark Returned" onAction="#handleMarkReturned"
                            style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 6; -fx-padding: 7 14; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
