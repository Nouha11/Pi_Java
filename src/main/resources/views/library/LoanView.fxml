<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.LoanController"
            style="-fx-background-color: #f0f4f8;">
    <stylesheets><URL value="@../../css/library.css"/></stylesheets>

    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #0f172a, #1e293b, #0f3460);
                     -fx-padding: 20 28 16 28;" spacing="14">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS" spacing="3">
                    <Label text="Loan Management"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Review and manage all book loan requests"
                           style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>
                <ComboBox fx:id="filterStatus" prefWidth="160"
                          style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: rgba(255,255,255,0.2);
                                 -fx-border-radius: 8; -fx-text-fill: white;"/>
                <Button text="↺ Refresh" onAction="#handleRefresh"
                        style="-fx-background-color: linear-gradient(to right, #6366f1, #8b5cf6);
                               -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-padding: 8 18; -fx-cursor: hand;"/>
                <Label fx:id="statusLabel" text=""
                       style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.5);"/>
            </HBox>

            <!-- Stat strip -->
            <HBox spacing="12">
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(245,158,11,0.15); -fx-border-color: #f59e0b;
                             -fx-border-width: 0 0 0 3; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10 16;">
                    <Label fx:id="statPending" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                    <Label text="Pending" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(59,130,246,0.15); -fx-border-color: #3b82f6;
                             -fx-border-width: 0 0 0 3; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10 16;">
                    <Label fx:id="statApproved" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                    <Label text="Approved" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(16,185,129,0.15); -fx-border-color: #10b981;
                             -fx-border-width: 0 0 0 3; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10 16;">
                    <Label fx:id="statActive" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                    <Label text="Active" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(99,102,241,0.15); -fx-border-color: #6366f1;
                             -fx-border-width: 0 0 0 3; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10 16;">
                    <Label fx:id="statReturned" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #6366f1;"/>
                    <Label text="Returned" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(239,68,68,0.15); -fx-border-color: #ef4444;
                             -fx-border-width: 0 0 0 3; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10 16;">
                    <Label fx:id="statRejected" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                    <Label text="Rejected" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox fx:id="loansContainer" spacing="10" style="-fx-padding: 20 24;"/>
        </ScrollPane>
    </center>
</BorderPane>
