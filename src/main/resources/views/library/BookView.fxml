<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.BookController"
            style="-fx-background-color: #f0f4f8;">
    <stylesheets>
        <URL value="@../../css/library.css"/>
    </stylesheets>

    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #1e1b4b, #312e81, #4338ca);
                     -fx-padding: 20 28 20 28;">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Books Management"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Manage your physical and digital book catalog"
                           style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.65);"/>
                </VBox>
                <Button text="+ Add New Book" onAction="#handleNew"
                        style="-fx-background-color: white; -fx-text-fill: #4338ca;
                               -fx-font-weight: bold; -fx-padding: 10 22;
                               -fx-background-radius: 8; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 6, 0, 0, 2);"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24;">

            <!-- Stat cards -->
            <HBox spacing="16">
                <VBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-border-radius: 14; -fx-padding: 20 24;
                             -fx-border-color: #4338ca; -fx-border-width: 0 0 0 5;
                             -fx-effect: dropshadow(gaussian, rgba(67,56,202,0.12), 10, 0, 0, 4);">
                    <Label fx:id="statTotalBooks" text="0"
                           style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill: #4338ca;"/>
                    <Label text="Total Books"
                           style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-border-radius: 14; -fx-padding: 20 24;
                             -fx-border-color: #059669; -fx-border-width: 0 0 0 5;
                             -fx-effect: dropshadow(gaussian, rgba(5,150,105,0.12), 10, 0, 0, 4);">
                    <Label fx:id="statPhysical" text="0"
                           style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                    <Label text="Physical Books"
                           style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-border-radius: 14; -fx-padding: 20 24;
                             -fx-border-color: #7c3aed; -fx-border-width: 0 0 0 5;
                             -fx-effect: dropshadow(gaussian, rgba(124,58,237,0.12), 10, 0, 0, 4);">
                    <Label fx:id="statDigital" text="0"
                           style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>
                    <Label text="Digital (PDF)"
                           style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- Search + filter bar -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 14 20;
                         -fx-background-radius: 12; -fx-border-color: #e2e8f0;
                         -fx-border-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
                <TextField fx:id="searchField" promptText="Search title, author, ISBN..."
                           prefWidth="300"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 9 14; -fx-font-size: 13;"/>
                <ComboBox fx:id="filterType" prefWidth="160"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-padding: 4 8;"/>
                <Button text="Refresh" onAction="#handleRefresh"
                        style="-fx-background-color: #4338ca; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-padding: 9 18; -fx-cursor: hand;"/>
                <Label fx:id="statusLabel" text="" HBox.hgrow="ALWAYS"
                       style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>
            </HBox>

            <!-- Book cards list -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="booksContainer" spacing="14" style="-fx-padding: 2;"/>
            </ScrollPane>

        </VBox>
    </center>
</BorderPane>
