<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.BookController"
            style="-fx-background-color: #f8f9fa;">

    <!-- ── TOP HEADER ── -->
    <top>
        <VBox style="-fx-background-color: #ffffff; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;
                     -fx-padding: 16 24 16 24;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Books Management"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <Label text="Manage your physical and digital book catalog"
                           style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
                </VBox>

                <Button text="+ Add New Book" onAction="#handleNew"
                        style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── MAIN CONTENT ── -->
    <center>
        <VBox spacing="20" style="-fx-padding: 24;">

            <!-- Stat Cards Row -->
            <HBox spacing="16">
                <!-- Total Books -->
                <VBox fx:id="cardTotalBooks" alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #0d6efd; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 16 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statTotalBooks" text="0"
                           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0d6efd;"/>
                    <Label text="Total Books" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <!-- Physical -->
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #198754; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 16 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statPhysical" text="0"
                           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #198754;"/>
                    <Label text="Physical" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
                <!-- Digital -->
                <VBox alignment="CENTER" spacing="4"
                      style="-fx-background-color: white; -fx-border-color: #0dcaf0; -fx-border-width: 0 0 0 4;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 16 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      HBox.hgrow="ALWAYS">
                    <Label fx:id="statDigital" text="0"
                           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0dcaf0;"/>
                    <Label text="Digital (PDF)" style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                </VBox>
            </HBox>

            <!-- Card: Table -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-radius: 8;
                         -fx-border-color: #dee2e6; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                  VBox.vgrow="ALWAYS">

                <!-- Card Header -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 16 20; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                    <Label text="All Books" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #212529;"
                           HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" promptText="Search title, author, ISBN..."
                               prefWidth="220"
                               style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6;
                                      -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 10;"/>
                    <ComboBox fx:id="filterType" prefWidth="130"
                              style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 6;"/>
                    <Button text="↺ Refresh" onAction="#handleRefresh"
                            style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;"/>
                </HBox>

                <!-- Table -->
                <TableView fx:id="bookTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colId"     text="ID"     prefWidth="55"/>
                        <TableColumn fx:id="colTitle"  text="Title"  prefWidth="220"/>
                        <TableColumn fx:id="colAuthor" text="Author" prefWidth="160"/>
                        <TableColumn fx:id="colIsbn"   text="ISBN"   prefWidth="130"/>
                        <TableColumn fx:id="colPrice"  text="Price"  prefWidth="90"/>
                        <TableColumn fx:id="colType"   text="Type"   prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 40;">
                            <Label text="📚" style="-fx-font-size: 40;"/>
                            <Label text="No books found" style="-fx-font-size: 16; -fx-text-fill: #6c757d;"/>
                            <Label text="Add your first book using the button above."
                                   style="-fx-font-size: 13; -fx-text-fill: #adb5bd;"/>
                        </VBox>
                    </placeholder>
                </TableView>

                <!-- Card Footer: actions + status -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 12 20; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;
                             -fx-background-color: #f8f9fa; -fx-background-radius: 0 0 8 8;">
                    <Button text="✏ Edit" onAction="#handleEdit"
                            style="-fx-background-color: #ffc107; -fx-text-fill: #212529;
                                   -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
                    <Button text="🗑 Delete" onAction="#handleDelete"
                            style="-fx-background-color: #dc3545; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
                    <Label fx:id="statusLabel" text="" HBox.hgrow="ALWAYS"
                           style="-fx-font-size: 13; -fx-padding: 0 0 0 10;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
