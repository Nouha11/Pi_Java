<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.library.LoanFormController"
            style="-fx-background-color: #f8f9fa;">

    <top>
        <VBox style="-fx-background-color: #cfe2ff; -fx-padding: 20 24 20 24;">
            <Label text="📋 Request Book Loan"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
            <Label text="Home › Books › Libraries › Request Loan"
                   style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="24" style="-fx-padding: 24;" alignment="TOP_LEFT">

            <!-- LEFT: Loan form -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <VBox style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-padding: 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
                      spacing="16">

                    <Label text="📅 Loan Request Form"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #212529;
                                  -fx-padding: 0 0 8 0; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;"/>

                    <!-- Book info row -->
                    <HBox spacing="16" alignment="CENTER_LEFT"
                          style="-fx-background-color: #f8f9fa; -fx-padding: 12; -fx-background-radius: 6;">
                        <Label text="📖" style="-fx-font-size: 36;"/>
                        <VBox spacing="4">
                            <Label fx:id="lblBookTitle"
                                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                            <Label fx:id="lblBookAuthor" style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
                            <Label text="Physical Book"
                                   style="-fx-background-color: #cfe2ff; -fx-text-fill: #084298;
                                          -fx-padding: 2 10; -fx-background-radius: 20; -fx-font-size: 11;"/>
                        </VBox>
                    </HBox>

                    <!-- Selected library -->
                    <VBox spacing="6">
                        <Label text="Selected Library"
                               style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                        <HBox spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: #e7f1ff; -fx-border-color: #0d6efd;
                                     -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;
                                     -fx-padding: 12 16;">
                            <Label text="🏛" style="-fx-font-size: 24;"/>
                            <VBox spacing="2">
                                <Label fx:id="lblLibraryName"
                                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                                <Label fx:id="lblLibraryAddress"
                                       style="-fx-font-size: 12; -fx-text-fill: #6c757d;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Loan period -->
                    <Label text="Loan Period"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>

                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Pickup Date"
                                   style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 12;"/>
                            <DatePicker fx:id="pickupDate" maxWidth="Infinity"
                                        style="-fx-border-color: #dee2e6; -fx-border-radius: 6;"/>
                            <Label text="When will you pick up the book?"
                                   style="-fx-font-size: 11; -fx-text-fill: #6c757d;"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Return Date"
                                   style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 12;"/>
                            <DatePicker fx:id="returnDate" maxWidth="Infinity"
                                        style="-fx-border-color: #dee2e6; -fx-border-radius: 6;"/>
                            <Label text="When will you return the book?"
                                   style="-fx-font-size: 11; -fx-text-fill: #6c757d;"/>
                        </VBox>
                    </HBox>

                    <!-- Info box -->
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: #cff4fc; -fx-border-color: #9eeaf9;
                                 -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 12 16;">
                        <Label text="ℹ️" style="-fx-font-size: 18;"/>
                        <Label text="Books can be borrowed for a maximum of 14 days. Please return on time."
                               style="-fx-font-size: 12; -fx-text-fill: #055160;" wrapText="true"
                               HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Error label -->
                    <Label fx:id="lblError" text="" wrapText="true"
                           style="-fx-text-fill: #842029; -fx-background-color: #f8d7da;
                                  -fx-border-color: #f5c2c7; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 10 14; -fx-font-size: 13;"
                           visible="false"/>

                    <!-- Buttons -->
                    <HBox spacing="12">
                        <Button text="✅ Submit Loan Request" onAction="#handleSubmit"
                                style="-fx-background-color: #0d6efd; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-padding: 10 20; -fx-cursor: hand;"/>
                        <Button text="← Back to Libraries" onAction="#handleBack"
                                style="-fx-background-color: #f8f9fa; -fx-text-fill: #495057;
                                       -fx-border-color: #dee2e6; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-padding: 10 16; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- RIGHT: Loan summary sidebar -->
            <VBox prefWidth="260" spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #dee2e6; -fx-border-radius: 8;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

                <Label text="Loan Summary"
                       style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #212529;
                              -fx-padding: 16 20; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;"/>

                <VBox spacing="12" style="-fx-padding: 16 20;">
                    <Label text="Book Information"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>

                    <VBox spacing="8">
                        <HBox spacing="8">
                            <Label text="📖" style="-fx-font-size: 14;"/>
                            <Label fx:id="sideBookTitle" wrapText="true"
                                   style="-fx-font-size: 13; -fx-text-fill: #212529;" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="8">
                            <Label text="👤" style="-fx-font-size: 14;"/>
                            <Label fx:id="sideBookAuthor"
                                   style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
                        </HBox>
                        <HBox spacing="8">
                            <Label text="📄" style="-fx-font-size: 14;"/>
                            <Label text="Physical Book" style="-fx-font-size: 13; -fx-text-fill: #6c757d;"/>
                        </HBox>
                    </VBox>

                    <Separator/>

                    <Label text="Loan Benefits"
                           style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13;"/>
                    <VBox spacing="6">
                        <Label text="✅  Free borrowing" style="-fx-font-size: 12; -fx-text-fill: #212529;"/>
                        <Label text="✅  Up to 14 days" style="-fx-font-size: 12; -fx-text-fill: #212529;"/>
                        <Label text="✅  Renewable if available" style="-fx-font-size: 12; -fx-text-fill: #212529;"/>
                        <Label text="✅  No late fees (first time)" style="-fx-font-size: 12; -fx-text-fill: #212529;"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
