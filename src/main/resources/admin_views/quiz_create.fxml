<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.QuizController"
            style="-fx-font-family: Arial; -fx-font-size: 12;">

    <top>
        <VBox style="-fx-background-color: #2c3e50;" spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Quiz Management"
                   style="-fx-font-size: 24; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <HBox spacing="10">
                <Label text="Quiz Title:" minWidth="120"
                       style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <TextField fx:id="titleField"
                           promptText="Enter quiz title"
                           HBox.hgrow="ALWAYS"
                           style="-fx-font-size: 12; -fx-padding: 8;"/>
            </HBox>

            <HBox spacing="10" alignment="TOP_LEFT">
                <Label text="Description:" minWidth="120"
                       style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <TextArea fx:id="descriptionField"
                          promptText="Enter quiz description (optional)"
                          wrapText="true"
                          prefRowCount="6"
                          HBox.hgrow="ALWAYS"
                          style="-fx-font-size: 12; -fx-padding: 8;"/>
            </HBox>

            <Separator/>

            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="createButton"
                        text="Create Quiz"
                        onAction="#handleCreateQuiz"
                        style="-fx-font-size: 12; -fx-padding: 10 30; -fx-background-color: #27ae60; -fx-text-fill: white;"/>

                <Button fx:id="updateButton"
                        text="Update Quiz"
                        onAction="#handleUpdateQuiz"
                        visible="false"
                        style="-fx-font-size: 12; -fx-padding: 10 30; -fx-background-color: #f39c12; -fx-text-fill: white;"/>

                <Button fx:id="deleteButton"
                        text="Delete Quiz"
                        onAction="#handleDeleteQuiz"
                        visible="false"
                        style="-fx-font-size: 12; -fx-padding: 10 30; -fx-background-color: #c0392b; -fx-text-fill: white;"/>

                <Button fx:id="cancelButton"
                        text="Cancel"
                        onAction="#handleCancel"
                        style="-fx-font-size: 12; -fx-padding: 10 30; -fx-background-color: #e74c3c; -fx-text-fill: white;"/>
            </HBox>

            <Label fx:id="messageLabel"
                   style="-fx-font-size: 12; -fx-text-fill: #e74c3c;"/>
        </VBox>
    </center>

</BorderPane>
